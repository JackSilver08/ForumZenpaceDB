@model ForumZenpace.Models.ProfileViewModel
@{
    ViewData["Title"] = "Hồ Sơ Của Tôi";
}

<div class="glass-panel animated-entry" style="max-width: 800px; margin: 5rem auto; padding: 4rem; position: relative; overflow: hidden;">
    @* Decorative Blobs for Profile *@
    <div style="position: absolute; top: -100px; right: -100px; width: 300px; height: 300px; background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, transparent 70%); filter: blur(40px); pointer-events: none;"></div>
    <div style="position: absolute; bottom: -100px; left: -100px; width: 300px; height: 300px; background: radial-gradient(circle, rgba(236, 72, 153, 0.1) 0%, transparent 70%); filter: blur(40px); pointer-events: none;"></div>

    <div style="position: relative; z-index: 1;">
        <div style="text-align: center; margin-bottom: 4rem;">
            <h2 style="font-size: 2.5rem; font-weight: 900; letter-spacing: -1.5px; margin-bottom: 0.5rem;">Cài đặt hồ sơ</h2>
            <p style="color: var(--text-secondary); font-size: 1.1rem;">Cập nhật danh tính cá nhân của bạn trên Zenpace</p>
        </div>
        
        @if (ViewBag.SuccessMessage != null)
        {
            <div class="glass-card mb-5" style="padding: 1.25rem; background: rgba(16, 185, 129, 0.1); color: #10B981; border: 1px solid rgba(16, 185, 129, 0.2); text-align: center; border-radius: 12px; font-weight: 700;">
                <i class="fa-solid fa-circle-check" style="margin-right: 8px;"></i> @ViewBag.SuccessMessage
            </div>
        }

        <form asp-action="Update" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-4" style="font-size: 0.85rem; font-weight: 600;"></div>
            
            <div style="display: grid; grid-template-columns: 200px 1fr; gap: 4rem; align-items: start;">
                <div style="text-align: center;">
                    <div style="position: relative; width: 180px; height: 180px; margin: 0 auto; border-radius: 24px; padding: 6px; background: linear-gradient(135deg, rgba(255,255,255,0.2), rgba(255,255,255,0.05)); border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 20px 40px rgba(0,0,0,0.3);">
                        <div style="width: 100%; height: 100%; border-radius: 20px; overflow: hidden; background: #111;">
                            @if (string.IsNullOrEmpty(Model.Avatar))
                            {
                                <div style="width: 100%; height: 100%; background: var(--primary-gradient); display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 4rem; color: #fff; text-shadow: 0 5px 15px rgba(0,0,0,0.2);">
                                    @Model.Username.Substring(0, 1).ToUpper()
                                </div>
                            }
                            else
                            {
                                <img src="@Model.Avatar" style="width: 100%; height: 100%; object-fit: cover;" alt="Avatar" />
                            }
                        </div>
                        <div style="position: absolute; bottom: -12px; right: -12px; width: 44px; height: 44px; background: #fff; border-radius: 14px; display: flex; align-items: center; justify-content: center; color: #000; box-shadow: 0 10px 20px rgba(0,0,0,0.4); cursor: pointer; transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);" onmouseover="this.style.transform='scale(1.1) rotate(5deg)'" onmouseout="this.style.transform='scale(1) rotate(0deg)'">
                            <i class="fa-solid fa-camera"></i>
                        </div>
                    </div>
                    <div style="margin-top: 2rem;">
                        <span style="font-size: 0.75rem; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 2px;">@@@Model.Username</span>
                    </div>
                </div>

                <div style="display: flex; flex-direction: column; gap: 2rem;">
                    <div style="display: grid; grid-template-columns: 1fr; gap: 2rem;">
                        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                            <label asp-for="FullName" style="font-size: 0.8rem; font-weight: 800; color: #fff; text-transform: uppercase; letter-spacing: 1.5px;">Họ tên đầy đủ</label>
                            <input asp-for="FullName" class="form-control" placeholder="Tên hiển thị của bạn..." style="padding: 1rem; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px;" />
                            <span asp-validation-for="FullName" class="text-danger" style="font-size: 0.75rem; font-weight: 600;"></span>
                        </div>
                        
                        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                            <label asp-for="Email" style="font-size: 0.8rem; font-weight: 800; color: #fff; text-transform: uppercase; letter-spacing: 1.5px;">Địa chỉ Email</label>
                            <input asp-for="Email" class="form-control" type="email" placeholder="example@zenpace.com" style="padding: 1rem; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px;" />
                            <span asp-validation-for="Email" class="text-danger" style="font-size: 0.75rem; font-weight: 600;"></span>
                        </div>
                        
                        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                            <label asp-for="Avatar" style="font-size: 0.8rem; font-weight: 800; color: #fff; text-transform: uppercase; letter-spacing: 1.5px;">Đường dẫn Avatar (URL)</label>
                            <input asp-for="Avatar" class="form-control" placeholder="https://image-hosting.com/avatar.jpg" style="padding: 1rem; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px;" />
                            <span asp-validation-for="Avatar" class="text-danger" style="font-size: 0.75rem; font-weight: 600;"></span>
                        </div>
                    </div>
                    
                    <div style="margin-top: 1rem; display: flex; flex-direction: column; gap: 1rem;">
                        <button type="submit" class="btn btn-primary" style="padding: 1.25rem; border-radius: 16px; font-weight: 900; font-size: 1.1rem; box-shadow: 0 15px 30px rgba(59, 130, 246, 0.3);">Lưu thay đổi hồ sơ</button>
                        <p style="text-align: center; color: var(--text-muted); font-size: 0.8rem; font-weight: 600;">Thông tin sẽ được cập nhật ngay lập tức sau khi lưu.</p>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
