@using System.Linq
@model ForumZenpace.Models.ProfileViewModel
@{
    var displayName = string.IsNullOrWhiteSpace(Model.FullName)
        ? (Model.Username ?? "User")
        : Model.FullName;
    ViewData["Title"] = Model.IsOwner ? "Ho so cua toi" : $"Ho so {displayName}";
    var avatarSeed = string.IsNullOrWhiteSpace(displayName) ? "U" : displayName;
    var avatarInitial = avatarSeed.Substring(0, 1).ToUpperInvariant();
    var hasAvatar = !string.IsNullOrWhiteSpace(Model.Avatar);
    var hasPosts = Model.Posts.Any();
    var stories = Model.Stories.ToList();
    var activeStories = stories.Where(story => !story.IsExpired).ToList();
    var archivedStories = stories.Where(story => story.IsExpired).ToList();
    var hasStories = stories.Any();
    var hasValidationErrors = Model.IsOwner && ViewData.ModelState.ErrorCount > 0;
    var isPostsTab = Model.ActiveTab == "posts";
    var isStoriesTab = Model.ActiveTab == "stories";
    var isChatTab = Model.ActiveTab == "chat";
}

<div class="profile-shell animated-entry">
    <div class="profile-layout">
        <aside class="profile-sidebar">
            <section class="surface profile-summary-card">
                <div class="profile-summary-top">
                    <div class="profile-avatar-frame">
                        <div class="profile-avatar-panel">
                            <div class="profile-avatar-fallback" style="display: @(hasAvatar ? "none" : "flex");">
                                @avatarInitial
                            </div>
                            <img class="profile-avatar-image" src="@Model.Avatar" alt="@displayName" style="display: @(hasAvatar ? "block" : "none");" />
                        </div>

                        @if (Model.IsOwner)
                        {
                            <button type="button"
                                    class="profile-avatar-trigger"
                                    title="Chinh sua ho so"
                                    aria-label="Chinh sua ho so"
                                    aria-haspopup="dialog"
                                    aria-controls="profileEditModal"
                                    onclick="openProfileModal()">
                                <i class="fa-solid fa-pen"></i>
                            </button>
                        }
                    </div>
                </div>

                <div class="profile-identity">
                    <h1 class="profile-display-name">@displayName</h1>
                    <div class="profile-handle">@@@Model.Username</div>
                    <div class="profile-contact">
                        @(Model.IsOwner ? Model.Email : "Nhan tin truc tiep qua Zenpace de trao doi ve bai viet va chu de chung.")
                    </div>
                </div>

                <div class="profile-summary-stats">
                    <div class="profile-stat-chip">
                        <span class="profile-stat-label">Chu de</span>
                        <strong class="profile-stat-value">@Model.PostCount</strong>
                    </div>
                    <div class="profile-stat-chip">
                        <span class="profile-stat-label">Binh luan</span>
                        <strong class="profile-stat-value">@Model.TotalCommentCount</strong>
                    </div>
                    <div class="profile-stat-chip">
                        <span class="profile-stat-label">Luot xem</span>
                        <strong class="profile-stat-value">@Model.TotalViewCount</strong>
                    </div>
                </div>

                <div class="profile-summary-meta">
                    <span><i class="fa-regular fa-calendar"></i> Tham gia @Model.JoinedAt.ToString("MM/yyyy")</span>
                    <span>
                        <i class="fa-regular @(Model.IsOwner ? "fa-image" : "fa-paper-plane")"></i>
                        @(Model.IsOwner
                            ? (hasAvatar ? "Avatar dang hoat dong" : "Chua co avatar")
                            : "Co the lien lac qua tab chat")
                    </span>
                </div>

                <div class="profile-upload-note">
                    <p class="field-hint">
                        @(Model.IsOwner
                            ? "Nhan icon but chi de doi avatar va cap nhat thong tin co ban."
                            : "Trang nay hien thi bai viet cong khai va khung chat rieng giua hai ben.")
                    </p>
                </div>

                @if (ViewBag.SuccessMessage != null)
                {
                    <div class="profile-inline-alert">
                        <i class="fa-solid fa-circle-check"></i>
                        <span>@ViewBag.SuccessMessage</span>
                    </div>
                }

                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="profile-inline-alert is-error">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span>@ViewBag.ErrorMessage</span>
                    </div>
                }
            </section>
        </aside>

        <section class="profile-main">
            <div class="surface profile-content-card">
                <div class="profile-content-header">
                    <div>
                        <div class="panel-label">@(Model.IsOwner ? "Noi dung cua ban" : $"Trang ca nhan cua {displayName}")</div>
                        <h2 class="section-heading">
                            @(isStoriesTab
                                ? "Khoanh khac da dang"
                                : isChatTab
                                    ? $"Chat voi {displayName}"
                                    : "Bai viet da dang")
                        </h2>
                        <p class="surface-subtitle">
                            @(isStoriesTab
                                ? (Model.IsOwner
                                    ? "Story moi se hien trong 24 gio, sau do duoc luu lai de ban quan ly trong profile."
                                    : "Khoanh khac cua thanh vien nay chi hien voi ban be va duoc sap xep tu moi nhat den cu hon.")
                                : (isChatTab
                                    ? "Cuoc tro chuyen nay chi hien giua ban va nguoi dung duoc chon."
                                    : (Model.IsOwner
                                        ? "Cac chu de cong khai duoc sap xep theo thoi gian moi nhat."
                                        : "Cac bai viet cong khai cua thanh vien nay duoc sap xep theo thoi gian moi nhat.")))
                        </p>

                        @if (!Model.IsOwner && Model.IsAuthenticatedViewer)
                        {
                            <div class="profile-social-actions"
                                 data-profile-social
                                 data-target-user-id="@Model.ProfileUserId"
                                 data-target-username="@Model.Username"
                                 data-is-friend="@Model.IsFriend.ToString().ToLowerInvariant()"
                                 data-has-outgoing-request="@Model.HasOutgoingFriendRequest.ToString().ToLowerInvariant()"
                                 data-has-incoming-request="@Model.HasIncomingFriendRequest.ToString().ToLowerInvariant()"
                                 data-message-blocked-by-viewer="@Model.IsMessageBlockedByViewer.ToString().ToLowerInvariant()"
                                 data-message-blocked-by-other-user="@Model.IsMessageBlockedByOtherUser.ToString().ToLowerInvariant()">
                                @if (Model.IsFriend)
                                {
                                    <button type="button" class="btn btn-outline" data-social-remove-friend>
                                        <i class="fa-solid fa-user-minus"></i>
                                        <span>Xoa ban</span>
                                    </button>
                                }
                                else if (Model.HasOutgoingFriendRequest)
                                {
                                    <button type="button" class="btn btn-outline" disabled>
                                        <i class="fa-solid fa-paper-plane"></i>
                                        <span>Da gui loi moi</span>
                                    </button>
                                }
                                else if (Model.HasIncomingFriendRequest)
                                {
                                    <a asp-controller="Notification" asp-action="Index" class="btn btn-primary">
                                        <i class="fa-solid fa-bell"></i>
                                        <span>Mo thong bao de chap nhan</span>
                                    </a>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-primary" data-social-send-request>
                                        <i class="fa-solid fa-user-plus"></i>
                                        <span>Ket ban</span>
                                    </button>
                                }

                                <button type="button" class="btn btn-text" data-social-toggle-block>
                                    <i class="fa-solid fa-ban"></i>
                                    <span>@(Model.IsMessageBlockedByViewer ? "Bo chan tin nhan" : "Chan tin nhan")</span>
                                </button>
                            </div>

                            <div class="field-hint" data-profile-social-status>
                                @if (Model.IsFriend)
                                {
                                    <span>Hai ban dang la ban be tren Zenpace.</span>
                                }
                                else if (Model.HasOutgoingFriendRequest)
                                {
                                    <span>Ban da gui loi moi ket ban va dang cho phan hoi.</span>
                                }
                                else if (Model.HasIncomingFriendRequest)
                                {
                                    <span>Nguoi dung nay da gui loi moi ket ban cho ban. Hay vao thong bao de chap nhan.</span>
                                }
                                else if (Model.IsMessageBlockedByViewer)
                                {
                                    <span>Ban dang chan tin nhan tu nguoi dung nay.</span>
                                }
                                else if (Model.IsMessageBlockedByOtherUser)
                                {
                                    <span>Nguoi dung nay dang chan tin nhan voi ban.</span>
                                }
                                else
                                {
                                    <span>Ban co the ket ban, chat rieng hoac quan ly quyen nhan tin ngay tai day.</span>
                                }
                            </div>
                        }
                    </div>

                    <div class="profile-tabs" aria-label="Dieu huong ho so">
                        @if (Model.IsOwner)
                        {
                            <a asp-action="Index"
                               asp-route-tab="posts"
                               class="profile-tab @(isPostsTab ? "is-active" : string.Empty)"
                               aria-selected="@(isPostsTab.ToString().ToLowerInvariant())">
                                Posts
                                <span class="profile-tab-count">@Model.PostCount</span>
                            </a>
                            <a asp-action="Index"
                               asp-route-tab="stories"
                               class="profile-tab @(isStoriesTab ? "is-active" : string.Empty)"
                               aria-selected="@(isStoriesTab.ToString().ToLowerInvariant())">
                                Stories
                                <span class="profile-tab-count">@Model.StoryCount</span>
                            </a>
                        }
                        else
                        {
                            <a asp-action="UserProfile"
                               asp-route-username="@Model.Username"
                               asp-route-tab="posts"
                               class="profile-tab @(isPostsTab ? "is-active" : string.Empty)"
                               aria-selected="@(isPostsTab.ToString().ToLowerInvariant())">
                                Posts
                                <span class="profile-tab-count">@Model.PostCount</span>
                            </a>
                            @if (Model.ShowStoriesTab)
                            {
                                <a asp-action="UserProfile"
                                   asp-route-username="@Model.Username"
                                   asp-route-tab="stories"
                                   class="profile-tab @(isStoriesTab ? "is-active" : string.Empty)"
                                   aria-selected="@(isStoriesTab.ToString().ToLowerInvariant())">
                                    Stories
                                    <span class="profile-tab-count">@Model.StoryCount</span>
                                </a>
                            }
                            <a asp-action="UserProfile"
                               asp-route-username="@Model.Username"
                               asp-route-tab="chat"
                               class="profile-tab @(isChatTab ? "is-active" : string.Empty)"
                               aria-selected="@(isChatTab.ToString().ToLowerInvariant())"
                               data-chat-tab>
                                Chat
                                @if (Model.ChatMessageCount > 0)
                                {
                                    <span class="profile-tab-count" data-chat-count>@Model.ChatMessageCount</span>
                                }
                            </a>
                        }
                    </div>
                </div>

                @if (isPostsTab)
                {
                    @if (hasPosts)
                    {
                        <div class="profile-post-list">
                            @foreach (var post in Model.Posts)
                            {
                                <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id" class="glass-card profile-post-link">
                                    <div class="profile-post-head">
                                        <div class="profile-post-meta">
                                            @if (!string.IsNullOrWhiteSpace(post.CategoryName))
                                            {
                                                <span class="category-badge">@post.CategoryName</span>
                                            }
                                            <span>@post.CreatedAt.ToString("dd MMM yyyy")</span>
                                        </div>

                                        <span class="profile-post-open" aria-hidden="true">
                                            <i class="fa-solid fa-arrow-right"></i>
                                        </span>
                                    </div>

                                    <div class="profile-post-title">@post.Title</div>

                                    @if (!string.IsNullOrWhiteSpace(post.Excerpt))
                                    {
                                        <p class="profile-post-excerpt">@post.Excerpt</p>
                                    }

                                    <div class="profile-post-footer">
                                        <div class="profile-post-metrics">
                                            <span class="metric comments">
                                                <i class="fa-regular fa-comment-dots"></i>
                                                <span>@post.CommentCount binh luan</span>
                                            </span>
                                            <span class="metric">
                                                <i class="fa-regular fa-eye"></i>
                                                <span>@post.ViewCount luot xem</span>
                                            </span>
                                        </div>

                                        <span class="profile-post-cta">Mo chu de</span>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="profile-empty-state">
                            <div class="empty-icon">
                                <i class="fa-regular fa-message"></i>
                            </div>
                            <h3 class="section-heading">Chua co chu de nao</h3>
                            <p class="muted">
                                @(Model.IsOwner
                                    ? "Trang nay se tro thanh khu vuc chinh de theo doi bai viet cua ban sau khi ban dang chu de dau tien."
                                    : "Thanh vien nay hien chua cong khai chu de nao tren Zenpace.")
                            </p>
                            @if (Model.IsOwner)
                            {
                                <div>
                                    <a asp-controller="Post" asp-action="Create" class="btn btn-primary">Tao chu de moi</a>
                                </div>
                            }
                        </div>
                    }
                }
                else if (isStoriesTab)
                {
                    <div class="profile-story-shell">
                        <div class="profile-story-summary-row">
                            <div class="glass-card profile-story-metric">
                                <span class="profile-story-metric-label">Dang hien</span>
                                <strong class="profile-story-metric-value">@Model.ActiveStoryCount</strong>
                            </div>
                            <div class="glass-card profile-story-metric">
                                <span class="profile-story-metric-label">Archive</span>
                                <strong class="profile-story-metric-value">@Model.ArchivedStoryCount</strong>
                            </div>
                            <div class="glass-card profile-story-metric">
                                <span class="profile-story-metric-label">Tong story</span>
                                <strong class="profile-story-metric-value">@Model.StoryCount</strong>
                            </div>
                        </div>

                        @if (Model.IsOwner)
                        {
                            <div class="profile-story-cta">
                                <button type="button" class="btn btn-primary" data-open-story-modal>
                                    <i class="fa-solid fa-plus"></i>
                                    <span>Dang khoanh khac moi</span>
                                </button>
                                <p class="field-hint">Story moi se duoc thong bao toi ban be va tu dong chuyen vao archive sau 24 gio.</p>
                            </div>
                        }

                        @if (hasStories)
                        {
                            @if (activeStories.Any())
                            {
                                <div class="profile-story-section">
                                    <div class="profile-story-section-header">
                                        <div>
                                            <div class="panel-label">Dang hoat dong</div>
                                            <h3 class="section-heading">Story trong 24 gio</h3>
                                        </div>
                                        <span class="status-pill is-live">@activeStories.Count dang hien</span>
                                    </div>

                                    <div class="profile-story-grid">
                                        @foreach (var story in activeStories)
                                        {
                                            <article class="glass-card profile-story-card @(story.HasBeenViewedByViewer ? string.Empty : "profile-story-card--fresh")">
                                                <a asp-controller="Story"
                                                   asp-action="Viewer"
                                                   asp-route-id="@story.Id"
                                                   class="profile-story-card-link">
                                                    <div class="profile-story-card-preview story-surface story-surface--@story.BackgroundStyle">
                                                        @if (story.HasImage && !string.IsNullOrWhiteSpace(story.ImageUrl))
                                                        {
                                                            <img class="story-surface__image" src="@story.ImageUrl" alt="@story.PreviewText" />
                                                        }
                                                        <div class="story-surface__overlay"></div>
                                                        <div class="story-surface__copy">@story.PreviewText</div>
                                                    </div>

                                                    <div class="profile-story-card-body">
                                                        <div class="profile-story-card-meta">
                                                            <span>@story.CreatedAt.ToString("dd MMM yyyy, HH:mm")</span>
                                                            @if (!story.HasBeenViewedByViewer)
                                                            {
                                                                <span class="status-pill is-live">Moi</span>
                                                            }
                                                            @if (story.HasMusic)
                                                            {
                                                                <span class="badge-tag"><i class="fa-solid fa-music"></i> Nhac</span>
                                                            }
                                                        </div>
                                                        <p class="profile-story-card-caption">@story.PreviewText</p>
                                                        <div class="profile-story-card-footer">
                                                            <span><i class="fa-regular fa-eye"></i> @story.ViewCount luot xem</span>
                                                            <span><i class="fa-regular fa-clock"></i> Het han @story.ExpiresAt.ToString("dd MMM, HH:mm")</span>
                                                        </div>
                                                    </div>
                                                </a>

                                                @if (Model.IsOwner)
                                                {
                                                    <form asp-controller="Story" asp-action="Delete" method="post" class="profile-story-delete">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@story.Id" />
                                                        <input type="hidden" name="returnUrl" value="@($"{Context.Request.Path}{Context.Request.QueryString}")" />
                                                        <button type="submit" class="btn btn-text">Xoa</button>
                                                    </form>
                                                }
                                            </article>
                                        }
                                    </div>
                                </div>
                            }

                            @if (archivedStories.Any())
                            {
                                <div class="profile-story-section">
                                    <div class="profile-story-section-header">
                                        <div>
                                            <div class="panel-label">Luu tru</div>
                                            <h3 class="section-heading">Story da het han</h3>
                                        </div>
                                        <span class="status-pill is-muted">@archivedStories.Count trong archive</span>
                                    </div>

                                    <div class="profile-story-grid">
                                        @foreach (var story in archivedStories)
                                        {
                                            <article class="glass-card profile-story-card profile-story-card--archived">
                                                <a asp-controller="Story"
                                                   asp-action="Viewer"
                                                   asp-route-id="@story.Id"
                                                   class="profile-story-card-link">
                                                    <div class="profile-story-card-preview story-surface story-surface--@story.BackgroundStyle">
                                                        @if (story.HasImage && !string.IsNullOrWhiteSpace(story.ImageUrl))
                                                        {
                                                            <img class="story-surface__image" src="@story.ImageUrl" alt="@story.PreviewText" />
                                                        }
                                                        <div class="story-surface__overlay"></div>
                                                        <div class="story-surface__copy">@story.PreviewText</div>
                                                    </div>

                                                    <div class="profile-story-card-body">
                                                        <div class="profile-story-card-meta">
                                                            <span>@story.CreatedAt.ToString("dd MMM yyyy, HH:mm")</span>
                                                            <span class="status-pill is-muted">Archive</span>
                                                            @if (story.HasMusic)
                                                            {
                                                                <span class="badge-tag"><i class="fa-solid fa-music"></i> Nhac</span>
                                                            }
                                                        </div>
                                                        <p class="profile-story-card-caption">@story.PreviewText</p>
                                                        <div class="profile-story-card-footer">
                                                            <span><i class="fa-regular fa-eye"></i> @story.ViewCount luot xem</span>
                                                            <span><i class="fa-regular fa-clock"></i> Het han @story.ExpiresAt.ToString("dd MMM, HH:mm")</span>
                                                        </div>
                                                    </div>
                                                </a>

                                                @if (Model.IsOwner)
                                                {
                                                    <form asp-controller="Story" asp-action="Delete" method="post" class="profile-story-delete">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@story.Id" />
                                                        <input type="hidden" name="returnUrl" value="@($"{Context.Request.Path}{Context.Request.QueryString}")" />
                                                        <button type="submit" class="btn btn-text">Xoa</button>
                                                    </form>
                                                }
                                            </article>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="profile-empty-state">
                                <div class="empty-icon">
                                    <i class="fa-regular fa-images"></i>
                                </div>
                                <h3 class="section-heading">Chua co khoanh khac nao</h3>
                                <p class="muted">
                                    @(Model.IsOwner
                                        ? "Dang story dau tien de hien tren trang chu cua ban be trong 24 gio va luu lai trong archive profile."
                                        : "Thanh vien nay hien chua co story nao co the hien voi ban.")
                                </p>
                                @if (Model.IsOwner)
                                {
                                    <div>
                                        <button type="button" class="btn btn-primary" data-open-story-modal>Dang story moi</button>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
                else if (!Model.IsAuthenticatedViewer)
                {
                    <div class="profile-chat-guest">
                        <div class="empty-icon">
                            <i class="fa-regular fa-paper-plane"></i>
                        </div>
                        <h3 class="section-heading">Dang nhap de bat dau tro chuyen</h3>
                        <p class="muted">Ban can dang nhap de nhan tin rieng voi nguoi dung nay ngay tren trang ca nhan cua ho.</p>
                        <div>
                            <a asp-controller="Auth" asp-action="Login" class="btn btn-primary">Dang nhap</a>
                        </div>
                    </div>
                }
                else
                {
                    <div class="profile-chat-panel"
                         data-chat-panel
                         data-current-user-id="@Model.ViewerUserId"
                         data-target-user-id="@Model.ProfileUserId"
                         data-target-username="@Model.Username"
                         data-hub-url="@Url.Content("~/hubs/direct-messages")"
                         data-chat-can-send="@Model.CanSendMessages.ToString().ToLowerInvariant()"
                         data-chat-block-message="@Model.ChatAvailabilityMessage">
                        <div class="profile-chat-thread" data-chat-thread>
                            @if (Model.ChatMessages.Any())
                            {
                                @foreach (var message in Model.ChatMessages)
                                {
                                    <article class="profile-chat-message @(message.IsOwnMessage ? "profile-chat-message--own" : string.Empty)"
                                             data-chat-message-id="@message.Id">
                                        <div class="profile-chat-bubble">
                                            <div class="profile-chat-text">@message.Content</div>
                                        </div>
                                        <div class="profile-chat-meta">
                                            <span>@(message.IsOwnMessage ? "Ban" : message.SenderDisplayName)</span>
                                            <span class="dot"></span>
                                            <time datetime="@message.CreatedAt.ToString("O")">@message.CreatedAt.ToString("dd MMM, HH:mm")</time>
                                        </div>
                                    </article>
                                }
                            }
                            else
                            {
                                <div class="profile-chat-empty" data-chat-empty>
                                    <div class="empty-icon">
                                        <i class="fa-regular fa-comments"></i>
                                    </div>
                                    <h3 class="section-heading">Chua co tin nhan nao</h3>
                                    <p class="muted">Hay mo dau cuoc tro chuyen bang loi nhan dau tien gui toi @displayName.</p>
                                </div>
                            }
                        </div>

                        @if (Model.IsConversationBlocked && !string.IsNullOrWhiteSpace(Model.ChatAvailabilityMessage))
                        {
                            <div class="profile-chat-banner is-error" data-chat-banner>@Model.ChatAvailabilityMessage</div>
                        }

                        <form asp-action="SendMessage" method="post" class="profile-chat-composer" data-chat-form>
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="TargetUserId" value="@Model.ProfileUserId" />
                            <input type="hidden" name="Username" value="@Model.Username" />

                            <div class="field">
                                <label class="field-label" for="chatMessageBox">Tin nhan moi</label>
                                <textarea id="chatMessageBox"
                                          name="Content"
                                          class="form-control profile-chat-textarea"
                                          rows="2"
                                          maxlength="1000"
                                          data-chat-input
                                          data-emoji-input
                                          placeholder="Viet loi nhan lich su, ro rang va dung trong chu de..."></textarea>
                                <p class="field-hint">Nhan `Enter` de gui nhanh, `Shift + Enter` de xuong dong.</p>
                            </div>

                            <div class="profile-chat-actions">
                                <div class="profile-chat-toolbar">
                                    <button
                                        type="button"
                                        class="comment-emoji-trigger"
                                        data-emoji-trigger
                                        title="Dang tai emoji"
                                        aria-label="Chen emoji vao tin nhan"
                                        aria-haspopup="dialog"
                                        aria-expanded="false"
                                        disabled>
                                        <i class="fa-regular fa-face-smile"></i>
                                        <span>Emoji</span>
                                    </button>
                                    <span class="field-hint">Khong chia se mat khau, OTP hoac thong tin nhay cam qua chat.</span>
                                </div>

                                <div class="profile-chat-submit">
                                    <span class="profile-chat-status" data-chat-status hidden></span>
                                    <button type="submit" class="btn btn-primary" data-chat-submit>Gui tin nhan</button>
                                </div>
                            </div>
                        </form>

                        <div
                            class="comment-emoji-popover"
                            data-emoji-popover
                            role="dialog"
                            aria-label="Bang chon emoji"
                            aria-hidden="true"
                            hidden>
                            <emoji-picker class="comment-emoji-picker dark" data-emoji-picker></emoji-picker>
                        </div>
                    </div>
                }
            </div>
        </section>
    </div>
</div>

@if (Model.IsOwner)
{
    <div id="profileEditModal"
         class="profile-modal"
         data-open-on-load="@(hasValidationErrors ? "true" : "false")"
         hidden
         aria-hidden="true">
        <div class="profile-modal-backdrop" onclick="closeProfileModal()"></div>

        <div class="surface profile-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="profileEditTitle">
            <div class="profile-modal-header">
                <div>
                    <div class="panel-label">Chinh sua ho so</div>
                    <h2 id="profileEditTitle" class="section-heading">Avatar va thong tin co ban</h2>
                </div>

                <button type="button" class="profile-modal-close" aria-label="Dong popup" onclick="closeProfileModal()">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <form asp-action="Update" method="post" enctype="multipart/form-data" class="profile-modal-form">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="profile-modal-avatar-row">
                    <div class="profile-avatar-frame profile-modal-avatar-frame">
                        <div class="profile-avatar-panel">
                            <div id="modalAvatarFallback" class="profile-avatar-fallback" style="display: @(hasAvatar ? "none" : "flex");">
                                @avatarInitial
                            </div>
                            <img id="modalAvatarPreview" class="profile-avatar-image" src="@Model.Avatar" alt="@displayName" style="display: @(hasAvatar ? "block" : "none");" />
                        </div>
                    </div>

                    <div class="profile-modal-avatar-tools">
                        <input asp-for="AvatarFile" id="avatarUpload" type="file" accept=".jpg,.jpeg,.png,.gif,.webp" hidden />
                        <label for="avatarUpload" class="btn btn-outline">Chon avatar</label>
                        <p id="avatarFileName" class="field-hint">
                            @(hasAvatar ? "Anh dai dien hien tai dang duoc su dung." : "Chua co avatar. Chon anh moi de cap nhat.")
                        </p>
                        <span asp-validation-for="AvatarFile" class="text-danger"></span>
                        <p class="field-hint">Chap nhan JPG, PNG, GIF, WEBP. Gioi han toi da 5MB.</p>
                    </div>
                </div>

                <div class="stack-sm">
                    <div class="field">
                        <label asp-for="FullName" class="field-label">Ten hien thi</label>
                        <input asp-for="FullName" class="form-control" placeholder="Ten hien thi cua ban" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="field">
                        <label asp-for="Email" class="field-label">Dia chi email</label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="example@zenpace.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                </div>

                <div class="profile-modal-footer">
                    <button type="button" class="btn btn-text" onclick="closeProfileModal()">Huy</button>
                    <button type="submit" class="btn btn-primary">Luu thay doi</button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
    @if (Model.IsOwner)
    {
        <partial name="_ValidationScriptsPartial" />
    }

    @if (Model.CanSendMessages && isChatTab)
    {
        <script type="module" src="https://cdn.jsdelivr.net/npm/emoji-picker-element@@1.29.0/index.js"></script>
        <script src="~/js/comment-emoji.js" asp-append-version="true"></script>
    }

    <script>
        (() => {
            const chatPanel = document.querySelector('[data-chat-panel]');
            const chatThread = document.querySelector('[data-chat-thread]');
            if (chatThread instanceof HTMLElement) {
                chatThread.scrollTop = chatThread.scrollHeight;
            }

            const chatForm = document.querySelector('[data-chat-form]');
            const chatInput = document.querySelector('[data-chat-input]');
            const chatSubmit = document.querySelector('[data-chat-submit]');
            const chatStatus = document.querySelector('[data-chat-status]');
            let chatEmpty = document.querySelector('[data-chat-empty]');
            const chatTab = document.querySelector('[data-chat-tab]');
            let chatCount = document.querySelector('[data-chat-count]');

            if (chatPanel instanceof HTMLElement
                && chatForm instanceof HTMLFormElement
                && chatInput instanceof HTMLTextAreaElement
                && chatSubmit instanceof HTMLButtonElement
                && chatThread instanceof HTMLElement) {
                const currentUserId = Number.parseInt(chatPanel.dataset.currentUserId || '', 10);
                const targetUserId = Number.parseInt(chatPanel.dataset.targetUserId || '', 10);
                const targetUsername = chatPanel.dataset.targetUsername || '';
                const hubUrl = chatPanel.dataset.hubUrl || '';
                const signalRClient = window.signalR;
                const getCanSendMessages = () => chatPanel.dataset.chatCanSend === 'true';
                const seenMessageIds = new Set(
                    Array.from(chatThread.querySelectorAll('[data-chat-message-id]'))
                        .map((element) => Number.parseInt(element.getAttribute('data-chat-message-id') || '', 10))
                        .filter((messageId) => Number.isInteger(messageId) && messageId > 0)
                );
                let isSending = false;
                let realtimeReady = false;
                let connection = null;

                const autoResizeTextarea = () => {
                    chatInput.style.height = 'auto';
                    chatInput.style.height = `${Math.min(chatInput.scrollHeight, 180)}px`;
                };

                const updateComposerState = () => {
                    const canSendMessages = getCanSendMessages();
                    const hasContent = chatInput.value.trim().length > 0;
                    chatInput.disabled = !canSendMessages;
                    chatSubmit.disabled = !canSendMessages || isSending || !hasContent;
                    autoResizeTextarea();
                };

                const setStatus = (message, isError = false) => {
                    if (!(chatStatus instanceof HTMLElement)) {
                        return;
                    }

                    if (!message) {
                        chatStatus.hidden = true;
                        chatStatus.textContent = '';
                        chatStatus.classList.remove('is-error');
                        return;
                    }

                    chatStatus.hidden = false;
                    chatStatus.textContent = message;
                    chatStatus.classList.toggle('is-error', isError);
                };

                const extractErrorMessage = (error, fallbackMessage) => {
                    if (error && typeof error === 'object' && typeof error.message === 'string' && error.message.trim().length > 0) {
                        return error.message.trim();
                    }

                    return fallbackMessage;
                };

                const ensureCountBadge = () => {
                    if (!(chatTab instanceof HTMLElement)) {
                        return null;
                    }

                    if (chatCount instanceof HTMLElement) {
                        return chatCount;
                    }

                    const badge = document.createElement('span');
                    badge.className = 'profile-tab-count';
                    badge.setAttribute('data-chat-count', '');
                    badge.textContent = '0';
                    chatTab.appendChild(badge);
                    chatCount = badge;
                    return badge;
                };

                const appendMessage = (message) => {
                    const messageId = Number.parseInt(`${message.id ?? ''}`, 10);
                    if (Number.isInteger(messageId) && messageId > 0) {
                        if (seenMessageIds.has(messageId)) {
                            return;
                        }

                        seenMessageIds.add(messageId);
                    }

                    if (chatEmpty instanceof HTMLElement) {
                        chatEmpty.remove();
                        chatEmpty = null;
                    }

                    const isOwnMessage = Number.parseInt(`${message.senderId ?? ''}`, 10) === currentUserId;
                    const article = document.createElement('article');
                    article.className = 'profile-chat-message';
                    if (Number.isInteger(messageId) && messageId > 0) {
                        article.setAttribute('data-chat-message-id', `${messageId}`);
                    }

                    if (isOwnMessage) {
                        article.classList.add('profile-chat-message--own');
                    }

                    const bubble = document.createElement('div');
                    bubble.className = 'profile-chat-bubble';

                    const text = document.createElement('div');
                    text.className = 'profile-chat-text';
                    text.textContent = message.content;
                    bubble.appendChild(text);

                    const meta = document.createElement('div');
                    meta.className = 'profile-chat-meta';

                    const sender = document.createElement('span');
                    sender.textContent = isOwnMessage ? 'Ban' : (message.senderDisplayName || 'Nguoi dung');
                    meta.appendChild(sender);

                    const dot = document.createElement('span');
                    dot.className = 'dot';
                    meta.appendChild(dot);

                    const time = document.createElement('time');
                    if (typeof message.createdAtIso === 'string' && message.createdAtIso.length > 0) {
                        time.dateTime = message.createdAtIso;
                    }

                    time.textContent = message.createdAtDisplay || '';
                    meta.appendChild(time);

                    article.appendChild(bubble);
                    article.appendChild(meta);
                    chatThread.appendChild(article);
                    chatThread.scrollTop = chatThread.scrollHeight;

                    const badge = ensureCountBadge();
                    if (badge instanceof HTMLElement) {
                        const nextCount = Number.parseInt(badge.textContent || '0', 10) + 1;
                        badge.textContent = `${nextCount}`;
                    }

                    if (!isOwnMessage && connection && realtimeReady) {
                        connection.invoke('MarkConversationAsRead', targetUserId).catch(() => {});
                    }
                };

                const sendViaHttp = async () => {
                    const response = await fetch(chatForm.action, {
                        method: 'POST',
                        body: new FormData(chatForm),
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });

                    const data = await response.json();
                    if (!response.ok || !data.success || !data.message) {
                        throw new Error(data.message || 'Khong the gui tin nhan luc nay.');
                    }

                    appendMessage(data.message);
                };

                const connectRealtime = async () => {
                    if (!signalRClient
                        || typeof signalRClient.HubConnectionBuilder !== 'function'
                        || !Number.isInteger(currentUserId)
                        || currentUserId <= 0
                        || !Number.isInteger(targetUserId)
                        || targetUserId <= 0
                        || !hubUrl) {
                        return;
                    }

                    connection = new signalRClient.HubConnectionBuilder()
                        .withUrl(hubUrl)
                        .withAutomaticReconnect()
                        .build();

                    connection.on('DirectMessageReceived', (message) => {
                        appendMessage(message);
                    });

                    connection.onreconnecting(() => {
                        realtimeReady = false;
                        setStatus('Ket noi realtime dang duoc khoi phuc...');
                    });

                    connection.onreconnected(async () => {
                        try {
                            await connection.invoke('JoinConversation', targetUserId);
                            realtimeReady = true;
                            setStatus('');
                        } catch {
                            realtimeReady = false;
                            setStatus('Realtime tam thoi gian doan. He thong se tiep tuc gui thuong.');
                        }
                    });

                    connection.onclose(() => {
                        realtimeReady = false;
                        setStatus('Realtime tam thoi gian doan. He thong se tiep tuc gui thuong.');
                    });

                    try {
                        await connection.start();
                        await connection.invoke('JoinConversation', targetUserId);
                        realtimeReady = true;
                        setStatus('');
                    } catch {
                        realtimeReady = false;
                        setStatus('Khong the ket noi realtime. He thong se tiep tuc gui thuong.');
                    }
                };

                chatInput.addEventListener('input', updateComposerState);
                chatInput.addEventListener('keydown', (event) => {
                    if (!getCanSendMessages()) {
                        return;
                    }

                    if (event.key !== 'Enter' || event.shiftKey || event.isComposing) {
                        return;
                    }

                    event.preventDefault();
                    if (chatInput.value.trim().length === 0) {
                        return;
                    }

                    chatForm.requestSubmit();
                });

                chatForm.addEventListener('submit', async (event) => {
                    event.preventDefault();

                    const content = chatInput.value.trim();
                    if (!getCanSendMessages()) {
                        setStatus(chatPanel.dataset.chatBlockMessage || 'Khong the gui tin nhan luc nay.', true);
                        return;
                    }

                    if (!content) {
                        setStatus('Noi dung tin nhan khong duoc de trong.', true);
                        return;
                    }

                    isSending = true;
                    updateComposerState();
                    setStatus('');

                    try {
                        if (connection && realtimeReady) {
                            await connection.invoke('SendDirectMessage', {
                                targetUserId,
                                username: targetUsername,
                                content
                            });
                        } else {
                            await sendViaHttp();
                        }

                        chatInput.value = '';
                        setStatus('');
                        updateComposerState();
                        chatInput.focus();
                    } catch (error) {
                        setStatus(extractErrorMessage(error, 'Khong the gui tin nhan luc nay.'), true);
                    } finally {
                        isSending = false;
                        updateComposerState();
                    }
                });

                document.addEventListener('zenpace:chat-state-changed', () => {
                    updateComposerState();
                    if (!getCanSendMessages() && chatPanel.dataset.chatBlockMessage) {
                        setStatus(chatPanel.dataset.chatBlockMessage, true);
                    } else {
                        setStatus('');
                    }
                });

                updateComposerState();
                if (!getCanSendMessages() && chatPanel.dataset.chatBlockMessage) {
                    setStatus(chatPanel.dataset.chatBlockMessage, true);
                }
                connectRealtime();
            }

            const modal = document.getElementById('profileEditModal');
            const fileInput = document.getElementById('avatarUpload');
            const preview = document.getElementById('modalAvatarPreview');
            const fallback = document.getElementById('modalAvatarFallback');
            const fileName = document.getElementById('avatarFileName');
            const firstField = document.querySelector('#profileEditModal input[name="FullName"]');

            function openProfileModal() {
                if (!modal) {
                    return;
                }

                modal.hidden = false;
                modal.setAttribute('aria-hidden', 'false');
                document.body.classList.add('profile-modal-open');

                if (firstField instanceof HTMLElement) {
                    window.requestAnimationFrame(() => firstField.focus());
                }
            }

            function closeProfileModal() {
                if (!modal) {
                    return;
                }

                modal.hidden = true;
                modal.setAttribute('aria-hidden', 'true');
                document.body.classList.remove('profile-modal-open');
            }

            window.openProfileModal = openProfileModal;
            window.closeProfileModal = closeProfileModal;

            if (!modal || !fileInput || !preview || !fallback || !fileName) {
                return;
            }

            document.addEventListener('keydown', (event) => {
                if (event.key === 'Escape' && !modal.hidden) {
                    closeProfileModal();
                }
            });

            fileInput.addEventListener('change', (event) => {
                const input = event.target;
                const file = input.files && input.files[0];

                if (!file) {
                    return;
                }

                fileName.textContent = `Da chon: ${file.name}`;

                const reader = new FileReader();
                reader.onload = (loadEvent) => {
                    preview.src = loadEvent.target?.result ?? '';
                    preview.style.display = 'block';
                    fallback.style.display = 'none';
                };

                reader.readAsDataURL(file);
            });

            if (modal.dataset.openOnLoad === 'true') {
                openProfileModal();
            }
        })();
    </script>
}
