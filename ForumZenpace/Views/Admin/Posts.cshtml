@model IEnumerable<ForumZenpace.Models.Post>
@{
    ViewData["Title"] = "Quản Lý Bài Viết";
}

<div class="animated-entry" style="padding-top: 1.5rem;">
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3rem;">
        <div>
            <h1 style="font-size: 2.25rem; font-weight: 900; margin-bottom: 0.5rem; letter-spacing: -1px;">Nội dung thảo luận</h1>
            <p style="color: var(--text-secondary);">Kiểm duyệt và quản lý toàn bộ bài viết trên hệ thống</p>
        </div>
        <a asp-action="Dashboard" class="btn btn-outline" style="padding: 0.75rem 1.5rem; border-radius: 12px; font-size: 0.8rem;">
            <i class="fa-solid fa-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="glass-panel" style="padding: 1.5rem;">
        <div style="overflow-x: auto;">
            <table class="table" style="width: 100%; border-collapse: separate; border-spacing: 0;">
                <thead>
                    <tr style="text-align: left; border-bottom: 1px solid rgba(255,255,255,0.1);">
                        <th style="padding: 1.5rem 1.25rem; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px;">Tiêu đề bài viết</th>
                        <th style="padding: 1.5rem 1.25rem; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px;">Tác giả</th>
                        <th style="padding: 1.5rem 1.25rem; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px;">Chuyên mục</th>
                        <th style="padding: 1.5rem 1.25rem; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px;">Trạng thái</th>
                        <th style="padding: 1.5rem 1.25rem; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px;">Ngày đăng</th>
                        <th style="padding: 1.25rem; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px;">Lượt xem</th>
                        <th style="padding: 1.5rem 1.25rem; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var post in Model.OrderByDescending(p => p.CreatedAt))
                {
                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.05); transition: var(--transition-smooth);" onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background='transparent'">
                        <td style="padding: 1.25rem;">
                            <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id" target="_blank" style="color: #fff; font-weight: 700; text-decoration: none; font-size: 1rem; display: block; max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@post.Title</a>
                        </td>
                        <td style="padding: 1.25rem; color: var(--text-secondary); font-weight: 500;">@post.User.FullName</td>
                        <td style="padding: 1.25rem;">
                            <span class="badge-tag" style="background: rgba(59, 130, 246, 0.1); color: var(--accent-blue); border: 1px solid rgba(59, 130, 246, 0.2); font-size: 0.65rem;">@post.Category.Name</span>
                        </td>
                        <td style="padding: 1.25rem;">
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <span style="width: 8px; height: 8px; border-radius: 50%; background: @(post.Status == "Active" ? "#10B981" : "#EF4444");"></span>
                                <span style="font-size: 0.85rem; font-weight: 600; color: @(post.Status == "Active" ? "#10B981" : "#EF4444");">@(post.Status == "Active" ? "Công khai" : "Đã ẩn")</span>
                            </div>
                        </td>
                        <td style="padding: 1.25rem; color: var(--text-muted); font-size: 0.85rem;">@post.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td style="padding: 1.25rem; color: var(--text-secondary); font-weight: 700;">@post.ViewCount</td>
                        <td style="padding: 1.25rem;">
                            <div style="display: flex; gap: 10px;">
                                <form asp-action="TogglePostStatus" method="post" class="inline-form">
                                    <input type="hidden" name="id" value="@post.Id" />
                                    <button type="submit" class="btn btn-outline" style="padding: 0.4rem 0.8rem; border-radius: 8px; font-size: 0.7rem; font-weight: 800; border-color: @(post.Status == "Active" ? "rgba(236, 72, 153, 0.3)" : "rgba(139, 92, 246, 0.3)"); color: @(post.Status == "Active" ? "var(--accent-pink)" : "var(--accent-purple)");">
                                        @(post.Status == "Active" ? "Ẩn bài" : "Khôi phục")
                                    </button>
                                </form>
                                <form asp-action="DeletePost" method="post" class="inline-form" onsubmit="return confirm('Hành động này không thể hoàn tác. Xóa vĩnh viễn thảo luận này?');">
                                    <input type="hidden" name="id" value="@post.Id" />
                                    <button type="submit" class="btn btn-outline" style="padding: 0.4rem 0.6rem; border-radius: 8px; color: rgba(255,255,255,0.2); border-color: rgba(255,255,255,0.05);">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
