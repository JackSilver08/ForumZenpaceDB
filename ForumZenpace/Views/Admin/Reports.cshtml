@model IEnumerable<ForumZenpace.Models.Report>
@{
    ViewData["Title"] = "Bao cao vi pham";
}

<div class="admin-shell animated-entry">
    <div class="admin-header">
        <div>
            <h1 class="admin-title">Bao cao vi pham</h1>
            <p class="admin-subtitle">Trang xu ly bao cao da duoc dua ve bang compact, uu tien ly do va thao tac quan tri.</p>
        </div>

        <a asp-action="Dashboard" class="btn btn-outline">
            <i class="fa-solid fa-arrow-left"></i> Quay lai
        </a>
    </div>

    <div class="surface admin-table-shell">
        <div class="scroll-x">
            <table class="table">
                <thead>
                    <tr>
                        <th>Noi dung bi bao cao</th>
                        <th>Nguoi gui</th>
                        <th>Ly do</th>
                        <th>Thoi diem</th>
                        <th>Xu ly</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var report in Model)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Post" asp-action="Details" asp-route-id="@report.PostId" target="_blank" class="table-link">@report.Post?.Title</a>
                            </td>
                            <td>@report.User?.FullName</td>
                            <td><span class="badge-tag">@report.Reason</span></td>
                            <td class="table-note">@report.CreatedAt.ToString("dd MMM, HH:mm")</td>
                            <td>
                                <div class="admin-actions">
                                    <form asp-action="TogglePostStatus" method="post" class="inline-form">
                                        <input type="hidden" name="id" value="@report.PostId" />
                                        <button type="submit" class="btn btn-outline">
                                            @(report.Post?.Status == "Active" ? "An noi dung" : "Khoi phuc")
                                        </button>
                                    </form>

                                    <form asp-action="DeletePost" method="post" class="inline-form" onsubmit="return confirm('Ban co chac chan muon xoa noi dung nay?');">
                                        <input type="hidden" name="id" value="@report.PostId" />
                                        <button type="submit" class="btn btn-danger-soft">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
