@model IEnumerable<ForumZenpace.Models.Category>

<div class="admin-shell animated-entry">
    <div class="admin-header">
        <div>
            <h1 class="admin-title">Quan ly chuyen muc</h1>
            <p class="admin-subtitle">Bang danh muc va form tao moi duoc rut gon de thao tac nhanh hon.</p>
        </div>

        <a asp-action="Dashboard" class="btn btn-outline">
            <i class="fa-solid fa-arrow-left"></i> Quay lai
        </a>
    </div>

    <div class="admin-layout">
        <div class="surface admin-table-shell">
            <div class="scroll-x">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Ma</th>
                            <th>Ten danh muc</th>
                            <th>So bai viet</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var category in Model)
                        {
                            <tr>
                                <td class="table-note">#@category.Id.ToString("D2")</td>
                                <td><strong>@category.Name</strong></td>
                                <td><span class="badge-tag">@category.Posts.Count bai</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="admin-sidecard">
            <div class="surface">
                <div class="panel-label">Them moi</div>
                <h2 class="section-heading" style="margin-bottom: 16px;">Tao chuyen muc</h2>

                <form asp-action="AddCategory" method="post" class="stack-md">
                    <div class="field">
                        <label class="field-label">Ten danh muc</label>
                        <input type="text" name="name" class="form-control" required placeholder="Nhap ten danh muc..." />
                    </div>

                    <button type="submit" class="btn btn-primary" style="width: 100%;">Them danh muc</button>
                </form>
            </div>

            <div class="admin-note">
                Nen dat ten ngan, ro rang va phan biet tot giua cac nhom thao luan.
            </div>
        </div>
    </div>
</div>
