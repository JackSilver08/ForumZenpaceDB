<div class="animated-entry" style="padding-top: 1.5rem;">
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3.5rem;">
        <div>
            <h1 style="font-size: 2.25rem; font-weight: 900; margin-bottom: 0.5rem; letter-spacing: -1px;">Cấu trúc chuyên mục</h1>
            <p style="color: var(--text-secondary);">Phân loại nội dung để tối ưu hóa trải nghiệm tìm kiếm</p>
        </div>
        <a asp-action="Dashboard" class="btn btn-outline" style="padding: 0.75rem 1.5rem; border-radius: 12px; font-size: 0.8rem;">
            <i class="fa-solid fa-arrow-left"></i> Quay lại
        </a>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 400px; gap: 2.5rem;">
        <!-- List -->
        <div class="glass-panel" style="padding: 1.5rem;">
            <div style="overflow-x: auto;">
                <table class="table" style="width: 100%; border-collapse: separate; border-spacing: 0;">
                    <thead>
                        <tr style="text-align: left; border-bottom: 1px solid rgba(255,255,255,0.1);">
                            <th style="padding: 1.5rem 1.25rem; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px;">Mã định danh</th>
                            <th style="padding: 1.5rem 1.25rem; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px;">Tên danh mục</th>
                            <th style="padding: 1.5rem 1.25rem; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px;">Số lượng bài</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var cat in Model)
                    {
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.05); transition: var(--transition-smooth);" onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background='transparent'">
                            <td style="padding: 1.25rem; color: var(--text-muted); font-weight: 800; font-family: monospace;">#@cat.Id.ToString("D2")</td>
                            <td style="padding: 1.25rem; font-weight: 700; color: #fff; font-size: 1.1rem;">@cat.Name</td>
                            <td style="padding: 1.25rem;">
                                <span style="font-weight: 800; color: var(--accent-purple); background: rgba(139, 92, 246, 0.1); padding: 0.4rem 0.8rem; border-radius: 8px;">@cat.Posts.Count</span>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
        
        <!-- Add new -->
        <div style="display: flex; flex-direction: column; gap: 2rem;">
            <div class="glass-panel" style="padding: 2.5rem; background: linear-gradient(135deg, rgba(59, 130, 246, 0.05), rgba(139, 92, 246, 0.05));">
                <h3 style="font-size: 1.1rem; font-weight: 800; color: #fff; margin-bottom: 2rem; display: flex; align-items: center; gap: 12px;">
                    <i class="fa-solid fa-folder-plus" style="color: var(--accent-blue);"></i> Khởi tạo danh mục
                </h3>
                <form asp-action="AddCategory" method="post" style="display: flex; flex-direction: column; gap: 1.5rem;">
                    <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                        <label style="font-size: 0.8rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px;">Tên gọi chuyên mục</label>
                        <input type="text" name="name" class="form-control" required placeholder="Nhập tên danh mục..." style="border-radius: 12px;" />
                    </div>
                    <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem; border-radius: 12px; font-weight: 800;">Hoàn tất thêm mới</button>
                </form>
            </div>
            
            <div class="glass-panel" style="padding: 1.5rem; border-style: dashed; border-color: rgba(255,255,255,0.1); background: transparent;">
                <p style="font-size: 0.85rem; color: var(--text-muted); line-height: 1.6;"><strong>Lưu ý:</strong> Nên đặt tên danh mục ngắn gọn, súc tích và bao quát được chủ đề thảo luận.</p>
            </div>
        </div>
    </div>
</div>
