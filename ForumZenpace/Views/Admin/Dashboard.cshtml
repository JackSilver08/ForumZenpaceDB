@{
    ViewData["Title"] = "Bang quan tri";
    var stats = ViewBag.Stats;
    var topLiked = (ForumZenpace.Models.Post)stats.TopLiked;
    var topViewed = (ForumZenpace.Models.Post)stats.TopViewed;
}

<div class="admin-shell animated-entry">
    <div class="admin-header">
        <div>
            <h1 class="admin-title">Bang quan tri</h1>
            <p class="admin-subtitle">Tong quan he thong voi mat do hien thi gon hon, uu tien thong tin va thao tac nhanh.</p>
        </div>

        <div class="admin-meta">
            <i class="fa-regular fa-clock"></i> Cap nhat @DateTime.Now.ToString("HH:mm")
        </div>
    </div>

    <div class="admin-stats">
        <div class="surface admin-stat">
            <div class="admin-stat-label">Nguoi dung</div>
            <div class="admin-stat-value">@stats.TotalUsers</div>
            <div class="admin-stat-trend" style="color: var(--accent-green);">Tang truong on dinh</div>
        </div>

        <div class="surface admin-stat">
            <div class="admin-stat-label">Chu de</div>
            <div class="admin-stat-value">@stats.TotalPosts</div>
            <div class="admin-stat-trend" style="color: var(--accent-purple);">Noi dung dang tang</div>
        </div>

        <div class="surface admin-stat">
            <div class="admin-stat-label">Bao cao cho</div>
            <div class="admin-stat-value" style="color: var(--accent-pink);">@stats.PendingReports</div>
            <div class="admin-stat-trend" style="color: var(--accent-pink);">Can uu tien xu ly</div>
        </div>
    </div>

    <div class="admin-grid-2">
        <div class="surface admin-card">
            <div class="panel-label">Noi bat</div>
            <h2 class="section-heading" style="margin-bottom: 16px;">Chu de duoc de xuat nhieu</h2>

            @if (topLiked != null)
            {
                <div class="glass-card summary-card">
                    <a asp-controller="Post" asp-action="Details" asp-route-id="@topLiked.Id" class="summary-link">@topLiked.Title</a>
                    <div class="summary-footer">
                        <span class="table-note">@topLiked.User?.FullName</span>
                        <span class="badge-tag"><i class="fa-solid fa-heart"></i> @topLiked.Likes?.Count</span>
                    </div>
                </div>
            }
        </div>

        <div class="surface admin-card">
            <div class="panel-label">Thinh hanh</div>
            <h2 class="section-heading" style="margin-bottom: 16px;">Chu de co luot xem cao</h2>

            @if (topViewed != null)
            {
                <div class="glass-card summary-card">
                    <a asp-controller="Post" asp-action="Details" asp-route-id="@topViewed.Id" class="summary-link">@topViewed.Title</a>
                    <div class="summary-footer">
                        <span class="table-note">@topViewed.User?.FullName</span>
                        <span class="badge-tag"><i class="fa-regular fa-eye"></i> @topViewed.ViewCount</span>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="surface admin-card">
        <div class="panel-label">Loi tat</div>
        <h2 class="section-heading" style="margin-bottom: 16px;">Dieu huong quan tri</h2>

        <div class="admin-shortcuts">
            <a asp-action="Users" class="glass-card admin-shortcut">
                <div class="admin-shortcut-icon" style="color: var(--accent-blue);"><i class="fa-solid fa-user-gear"></i></div>
                <div class="admin-shortcut-title">Hoi vien</div>
                <div class="admin-shortcut-meta">Quan ly tai khoan</div>
            </a>

            <a asp-action="Posts" class="glass-card admin-shortcut">
                <div class="admin-shortcut-icon" style="color: var(--accent-purple);"><i class="fa-solid fa-newspaper"></i></div>
                <div class="admin-shortcut-title">Noi dung</div>
                <div class="admin-shortcut-meta">Kiem duyet chu de</div>
            </a>

            <a asp-action="Categories" class="glass-card admin-shortcut">
                <div class="admin-shortcut-icon" style="color: var(--accent-pink);"><i class="fa-solid fa-tags"></i></div>
                <div class="admin-shortcut-title">Chuyen muc</div>
                <div class="admin-shortcut-meta">Sap xep cau truc</div>
            </a>

            <a asp-action="Reports" class="glass-card admin-shortcut">
                <div class="admin-shortcut-icon" style="color: var(--accent-pink);"><i class="fa-solid fa-shield-halved"></i></div>
                <div class="admin-shortcut-title">Bao cao</div>
                <div class="admin-shortcut-meta">Xu ly vi pham</div>
            </a>
        </div>
    </div>
</div>
