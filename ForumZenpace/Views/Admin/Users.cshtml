@model IEnumerable<ForumZenpace.Models.User>
@{
    ViewData["Title"] = "Quan ly nguoi dung";
}

<div class="admin-shell animated-entry">
    <div class="admin-header">
        <div>
            <h1 class="admin-title">Quan ly hoi vien</h1>
            <p class="admin-subtitle">Bang user da duoc dua ve compact table de hien thi duoc nhieu dong hon tren man hinh desktop.</p>
        </div>

        <a asp-action="Dashboard" class="btn btn-outline">
            <i class="fa-solid fa-arrow-left"></i> Quay lai
        </a>
    </div>

    <div class="surface admin-table-shell">
        <div class="scroll-x">
            <table class="table">
                <thead>
                    <tr>
                        <th>Danh tinh</th>
                        <th>Ho ten</th>
                        <th>Vai tro</th>
                        <th>Trang thai</th>
                        <th>Gia nhap</th>
                        <th>Dieu khien</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td><strong>@@@user.Username</strong></td>
                            <td>@user.FullName</td>
                            <td>
                                <span class="badge-tag">@user.Role.Name</span>
                            </td>
                            <td>
                                <span class="status-pill @(user.IsActive ? "is-live" : "is-muted")">
                                    <span class="dot" style="background: currentColor;"></span>
                                    @(user.IsActive ? "Kich hoat" : "Bi khoa")
                                </span>
                            </td>
                            <td class="table-note">@user.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>
                                @if (user.Role.Name != "Admin")
                                {
                                    <form asp-action="ToggleUserStatus" method="post" class="inline-form">
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="btn btn-outline">
                                            @(user.IsActive ? "Vo hieu hoa" : "Kich hoat")
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
