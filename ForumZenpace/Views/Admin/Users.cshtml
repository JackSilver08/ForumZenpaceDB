@model IEnumerable<ForumZenpace.Models.User>
@{
    ViewData["Title"] = "Quản Lý Người Dùng";
}

<div class="animated-entry" style="padding-top: 1.5rem;">
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3rem;">
        <div>
            <h1 style="font-size: 2.25rem; font-weight: 900; margin-bottom: 0.5rem; letter-spacing: -1px;">Quản lý Hội viên</h1>
            <p style="color: var(--text-secondary);">Danh sách người dùng và phân quyền hệ thống Zenpace</p>
        </div>
        <a asp-action="Dashboard" class="btn btn-outline" style="padding: 0.75rem 1.5rem; border-radius: 12px; font-size: 0.8rem;">
            <i class="fa-solid fa-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="glass-panel" style="padding: 1.5rem;">
        <div style="overflow-x: auto;">
            <table class="table" style="width: 100%; border-collapse: separate; border-spacing: 0;">
                <thead>
                    <tr style="text-align: left; border-bottom: 1px solid rgba(255,255,255,0.1);">
                        <th style="padding: 1.5rem 1.25rem; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px;">Danh tính</th>
                        <th style="padding: 1.5rem 1.25rem; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px;">Họ tên đầy đủ</th>
                        <th style="padding: 1.5rem 1.25rem; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px;">Phân quyền</th>
                        <th style="padding: 1.5rem 1.25rem; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px;">Trạng thái</th>
                        <th style="padding: 1.5rem 1.25rem; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px;">Gia nhập</th>
                        <th style="padding: 1.5rem 1.25rem; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px;">Điều khiển</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var user in Model)
                {
                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.05); transition: var(--transition-smooth);" onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background='transparent'">
                        <td style="padding: 1.25rem; font-weight: 700; color: #fff;">@@@user.Username</td>
                        <td style="padding: 1.25rem; color: var(--text-secondary); font-weight: 500;">@user.FullName</td>
                        <td style="padding: 1.25rem;">
                            <span style="padding: 0.4rem 0.8rem; border-radius: 8px; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; background: @(user.Role.Name == "Admin" ? "rgba(236, 72, 153, 0.1)" : "rgba(139, 92, 246, 0.1)"); color: @(user.Role.Name == "Admin" ? "var(--accent-pink)" : "var(--accent-purple)"); border: 1px solid @(user.Role.Name == "Admin" ? "rgba(236, 72, 153, 0.2)" : "rgba(139, 92, 246, 0.2)");">@user.Role.Name</span>
                        </td>
                        <td style="padding: 1.25rem;">
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <span style="width: 8px; height: 8px; border-radius: 50%; background: @(user.IsActive ? "#10B981" : "#EF4444"); box-shadow: 0 0 10px @(user.IsActive ? "#10B981" : "#EF4444");"></span>
                                <span style="font-size: 0.85rem; font-weight: 600; color: @(user.IsActive ? "#10B981" : "#EF4444");">@(user.IsActive ? "Kích Hoạt" : "Bị Khóa")</span>
                            </div>
                        </td>
                        <td style="padding: 1.25rem; color: var(--text-muted); font-size: 0.85rem;">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td style="padding: 1.25rem;">
                            @if (user.Role.Name != "Admin")
                            {
                                <form asp-action="ToggleUserStatus" method="post" style="display: inline;">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn btn-outline" style="padding: 0.4rem 1rem; border-radius: 8px; font-size: 0.7rem; font-weight: 800; border-color: @(user.IsActive ? "rgba(236, 72, 153, 0.3)" : "rgba(59, 130, 246, 0.3)"); color: @(user.IsActive ? "var(--accent-pink)" : "var(--accent-blue)");">
                                        @(user.IsActive ? "Vô Hiệu Hóa" : "Kích Hoạt")
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
