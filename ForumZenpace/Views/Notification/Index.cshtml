@model IEnumerable<ForumZenpace.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
    var unreadCount = Model.Count(n => !n.IsRead);
}

<div style="max-width: 600px; margin: 0 auto;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <h1>Notifications @(unreadCount > 0 ? $"({unreadCount})" : "")</h1>
        @if (unreadCount > 0)
        {
            <form asp-action="MarkAllAsRead" method="post">
                <button type="submit" class="btn btn-sm btn-outline"><i class="fa-solid fa-check-double"></i> Mark All as Read</button>
            </form>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="card text-center" style="padding: 3rem; color: var(--text-muted);">
            <i class="fa-regular fa-bell-slash fa-3x" style="margin-bottom: 1rem; opacity: 0.5;"></i>
            <p>You have no notifications.</p>
        </div>
    }

    <div style="display: flex; flex-direction: column; gap: 1rem;">
        @foreach (var n in Model)
        {
            <div class="card" style="padding: 1rem; display: flex; justify-content: space-between; align-items: center; border-left: 4px solid @(n.IsRead ? "transparent" : "var(--primary)"); background: @(n.IsRead ? "var(--bg-card)" : "rgba(59,130,246,0.05)")">
                <div>
                    <div style="font-weight: @(n.IsRead ? "400" : "600"); color: @(n.IsRead ? "var(--text-muted)" : "#fff");">@n.Content</div>
                    <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.25rem;">@n.CreatedAt.ToString("MMM dd HH:mm")</div>
                </div>
                @if (!n.IsRead)
                {
                    <form asp-action="MarkAsRead" method="post">
                        <input type="hidden" name="id" value="@n.Id" />
                        <button type="submit" class="btn btn-sm btn-primary" style="padding: 0.25rem 0.5rem; border-radius: 999px;" title="Mark as read">
                            <i class="fa-solid fa-check"></i>
                        </button>
                    </form>
                }
            </div>
        }
    </div>
</div>
