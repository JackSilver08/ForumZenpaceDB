@model IEnumerable<ForumZenpace.Models.Notification>
@{
    ViewData["Title"] = "Thong bao";
    var unreadCount = Model.Count(n => !n.IsRead);
}

<div class="notice-shell animated-entry">
    <div class="surface">
        <div class="surface-header">
            <div>
                <h1 class="surface-title">Trung tam thong bao</h1>
                <p class="surface-subtitle">Danh sach thong bao duoc nen gon hon de uu tien kha nang quet nhanh va xu ly nhieu muc lien tuc.</p>
            </div>

            @if (unreadCount > 0)
            {
                <form asp-action="MarkAllAsRead" method="post">
                    <button type="submit" class="btn btn-outline">
                        <i class="fa-solid fa-check-double"></i> Danh dau da doc
                    </button>
                </form>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="fa-solid fa-bell-slash"></i>
                </div>
                <h2 class="section-heading">Chua co thong bao moi</h2>
                <p class="muted">Khi co binh luan, phan hoi hoac thay doi quan trong, ban se thay tai day.</p>
            </div>
        }
        else
        {
            <div class="notice-list">
                @foreach (var notification in Model)
                {
                    <div class="glass-card notice-item @(notification.IsRead ? "" : "notice-item--unread")">
                        <div class="notice-content">
                            <div class="notice-text">@notification.Content</div>
                            <div class="notice-meta">
                                <span><i class="fa-regular fa-clock"></i> @notification.CreatedAt.ToString("MMM dd, HH:mm")</span>
                                <span class="dot"></span>
                                <span>@(notification.IsRead ? "Da doc" : "Moi")</span>
                            </div>
                        </div>

                        @if (!notification.IsRead)
                        {
                            <form asp-action="MarkAsRead" method="post">
                                <input type="hidden" name="id" value="@notification.Id" />
                                <button type="submit" class="notice-action" title="Danh dau da doc">
                                    <i class="fa-solid fa-check"></i>
                                </button>
                            </form>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>
