@{
    var currentUserName = User.Identity?.Name ?? "User";
    var currentUserInitial = currentUserName.Substring(0, 1).ToUpperInvariant();
    var controllerName = ViewContext.RouteData.Values["controller"]?.ToString();
    var actionName = ViewContext.RouteData.Values["action"]?.ToString();
    var isHomeIndex = string.Equals(controllerName, "Home", StringComparison.OrdinalIgnoreCase)
        && string.Equals(actionName, "Index", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ForumZenpace</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="page-shell">
            <div class="navbar glass-panel animated-entry">
                <a class="logo" asp-controller="Home" asp-action="Index">
                    <span class="logo-mark">
                        <i class="fa-solid fa-diamond"></i>
                    </span>
                    <span>Zenpace</span>
                </a>

                @if (!isHomeIndex)
                {
                    <nav class="nav-links" aria-label="Primary">
                        <a asp-controller="Home" asp-action="Index">Kham pha</a>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-controller="Notification" asp-action="Index">Thong bao</a>
                        }
                        else
                        {
                            <a asp-controller="Auth" asp-action="Login">Dang nhap</a>
                        }
                        <a asp-controller="Home" asp-action="Privacy">Quy dinh</a>
                    </nav>
                }

                <div class="header-actions">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Post" asp-action="Create" class="btn btn-primary">
                            <i class="fa-solid fa-plus"></i>
                            <span>Chu de moi</span>
                        </a>

                        <a asp-controller="Notification" asp-action="Index" class="btn btn-outline icon-btn" title="Thong bao">
                            <i class="fa-solid fa-bell"></i>
                        </a>

                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-outline icon-btn" title="Quan tri">
                                <i class="fa-solid fa-shield-halved"></i>
                            </a>
                        }

                        <a asp-controller="Profile" asp-action="Index" class="user-badge">
                            <span class="user-name">@currentUserName</span>
                            <span class="avatar-badge">
                                @currentUserInitial
                            </span>
                        </a>

                        <form asp-controller="Auth" asp-action="Logout" method="post">
                            <button type="submit" class="btn btn-text icon-btn" title="Dang xuat">
                                <i class="fa-solid fa-arrow-right-from-bracket"></i>
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Auth" asp-action="Login" class="btn btn-text">Dang nhap</a>
                        <a asp-controller="Auth" asp-action="Register" class="btn btn-primary">Tao tai khoan</a>
                    }
                </div>
            </div>
        </div>
    </header>

    <main class="main-content">
        <div class="page-shell">
            @RenderBody()
        </div>
    </main>

    <footer class="footer">
        <div class="page-shell footer-shell">
            <p>&copy; @DateTime.Now.Year Zenpace</p>
            <p>Compact glass forum UI for focused discussion.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
