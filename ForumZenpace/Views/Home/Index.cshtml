@model IEnumerable<ForumZenpace.Models.Post>
@{
    ViewData["Title"] = "Latest Discussions";
}

<div class="grid" style="grid-template-columns: 1fr 300px;">
    <!-- Main Content -->
    <div>
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
            <h1>Latest Discussions</h1>
            <div>
                <a asp-action="Index" asp-route-sortOrder="newest" class="btn @(ViewBag.CurrentSort == "newest" || string.IsNullOrEmpty(ViewBag.CurrentSort) ? "btn-primary" : "btn-outline")" style="border-radius: 999px; padding: 4px 16px; font-size: 0.8rem;">Newest</a>
                <a asp-action="Index" asp-route-sortOrder="views" class="btn @(ViewBag.CurrentSort == "views" ? "btn-primary" : "btn-outline")" style="border-radius: 999px; padding: 4px 16px; font-size: 0.8rem;">Most Viewed</a>
                <a asp-action="Index" asp-route-sortOrder="likes" class="btn @(ViewBag.CurrentSort == "likes" ? "btn-primary" : "btn-outline")" style="border-radius: 999px; padding: 4px 16px; font-size: 0.8rem;">Top Liked</a>
            </div>
        </div>

        <div class="card" style="padding: 0;">
            @if (!Model.Any())
            {
                <div style="padding: 3rem; text-align: center; color: var(--text-muted);">
                    <i class="fa-solid fa-ghost fa-3x" style="margin-bottom: 1rem; opacity: 0.5;"></i>
                    <p>No discussions found. Be the first to start one!</p>
                </div>
            }
            @foreach (var post in Model)
            {
                <div class="post-card">
                    <div class="post-stats">
                        <div style="text-align: center; background: rgba(59,130,246,0.1); color: var(--primary); padding: 8px; border-radius: 8px; width: 50px;">
                            <i class="fa-solid fa-chevron-up"></i>
                            <div style="font-weight: 700; margin-top: 4px;">@post.Likes.Count</div>
                        </div>
                    </div>
                    <div class="post-content">
                        <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id" class="post-title" style="color: #fff;">@post.Title</a>
                        <p style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 0.5rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis;">
                            @post.Content
                        </p>
                        <div class="post-meta">
                            <span><i class="fa-regular fa-folder text-primary"></i> <span class="badge bg-success" style="opacity: 0.8;">@post.Category.Name</span></span>
                            <span><i class="fa-regular fa-user"></i> @post.User.FullName</span>
                            <span><i class="fa-regular fa-clock"></i> @post.CreatedAt.ToString("MMM dd, yyyy")</span>
                            <span><i class="fa-regular fa-comment"></i> @post.Comments.Count</span>
                            <span><i class="fa-regular fa-eye"></i> @post.ViewCount view@(post.ViewCount != 1 ? "s" : "")</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Sidebar -->
    <aside>
        <div class="card mb-4" style="padding: 1rem;">
            <h3 style="font-size: 1.1rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem;">Search</h3>
            <form asp-action="Index" method="get" style="display: flex; gap: 8px; margin-top: 1rem;">
                <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control" placeholder="Search discussions..." style="padding: 0.5rem;" />
                <button type="submit" class="btn btn-primary" style="padding: 0.5rem 1rem;"><i class="fa-solid fa-search"></i></button>
            </form>
        </div>

        <div class="card" style="padding: 1rem;">
            <h3 style="font-size: 1.1rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem;">Categories</h3>
            <div style="display: flex; flex-direction: column; gap: 8px; margin-top: 1rem;">
                <a asp-action="Index" class="btn btn-text" style="justify-content: flex-start; padding: 4px 8px; @(ViewBag.CurrentCategory == null ? "color: var(--primary); background: rgba(59,130,246,0.1);" : "")">All Topics</a>
                @foreach (var cat in ViewBag.Categories)
                {
                    <a asp-action="Index" asp-route-categoryId="@cat.Id" class="btn btn-text" style="justify-content: flex-start; padding: 4px 8px; @(ViewBag.CurrentCategory == cat.Id ? "color: var(--primary); background: rgba(59,130,246,0.1);" : "")">
                        @cat.Name
                    </a>
                }
            </div>
        </div>
    </aside>
</div>
