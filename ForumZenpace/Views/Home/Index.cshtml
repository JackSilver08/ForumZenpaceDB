@using System.Linq
@using ForumZenpace.Models
@model IEnumerable<Post>
@{
    ViewData["Title"] = "Bang tin";

    var posts = Model?.ToList() ?? new List<Post>();
    var categories = (ViewData["Categories"] as IEnumerable<Category> ?? Enumerable.Empty<Category>()).ToList();
    var currentSort = (Convert.ToString(ViewData["CurrentSort"]) ?? string.Empty).ToLowerInvariant();
    var searchString = Convert.ToString(ViewData["SearchString"]);
    var currentCategoryValue = ViewData["CurrentCategory"];
    int? currentCategory = currentCategoryValue switch
    {
        int categoryId => categoryId,
        string categoryText when int.TryParse(categoryText, out var parsedCategoryId) => parsedCategoryId,
        _ => null
    };
    var sortRoute = string.IsNullOrEmpty(currentSort) ? null : currentSort;
    var searchRoute = string.IsNullOrWhiteSpace(searchString) ? null : searchString;
    string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return "?";
        }

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1)
        {
            return parts[0][0].ToString().ToUpperInvariant();
        }

        return string.Concat(parts[0][0], parts[^1][0]).ToUpperInvariant();
    }

    string GetExcerpt(string? content)
    {
        return PostContentFormatter.ToExcerpt(content, 180);
    }
}

<div class="home-toolbar animated-entry">
    <div class="home-toolbar-main">
        <div class="feed-controls">
            <div class="segmented-control glass-panel">
                <a asp-action="Index"
                   asp-route-sortOrder="newest"
                   asp-route-categoryId="@currentCategory"
                   asp-route-searchString="@searchRoute"
                   class="btn @(string.IsNullOrEmpty(currentSort) || currentSort == "newest" ? "btn-primary" : "btn-text")">
                    Moi nhat
                </a>
                <a asp-action="Index"
                   asp-route-sortOrder="views"
                   asp-route-categoryId="@currentCategory"
                   asp-route-searchString="@searchRoute"
                   class="btn @(currentSort == "views" ? "btn-primary" : "btn-text")">
                    Xem nhieu
                </a>
                <a asp-action="Index"
                   asp-route-sortOrder="likes"
                   asp-route-categoryId="@currentCategory"
                   asp-route-searchString="@searchRoute"
                   class="btn @(currentSort == "likes" ? "btn-primary" : "btn-text")">
                    De xuat
                </a>
            </div>
        </div>
    </div>
</div>

<div class="forum-page animated-entry">
    <aside class="forum-column forum-sidebar">
        <div class="glass-panel sidebar-panel">
            <div class="panel-label">Danh muc</div>

            <a asp-action="Index"
               asp-route-sortOrder="@sortRoute"
               asp-route-searchString="@searchRoute"
               class="sidebar-link @(!currentCategory.HasValue ? "active" : "")">
                <i class="fa-solid fa-layer-group"></i>
                <span>Tat ca</span>
            </a>

            @foreach (var category in categories)
            {
                <a asp-action="Index"
                   asp-route-categoryId="@category.Id"
                   asp-route-sortOrder="@sortRoute"
                   asp-route-searchString="@searchRoute"
                   class="sidebar-link @(currentCategory == category.Id ? "active" : "")">
                    <i class="fa-solid fa-hashtag"></i>
                    <span>@category.Name</span>
                </a>
            }
        </div>
    </aside>

    <section class="forum-column forum-main">
        @if (!posts.Any())
        {
            <div class="glass-panel empty-state">
                <div class="empty-icon">
                    <i class="fa-regular fa-message"></i>
                </div>
                <h2 class="section-heading">Chua co chu de nao</h2>
                <p class="muted">Thu thay doi bo loc, tim kiem lai, hoac bat dau mot bai viet moi de kich hoat bang tin.</p>
                <div>
                    <a asp-controller="Post" asp-action="Create" class="btn btn-primary">Tao chu de dau tien</a>
                </div>
            </div>
        }
        else
        {
            <div class="post-list">
                @foreach (var post in posts)
                {
                    <article class="glass-panel post-card">
                        <div class="post-card-header">
                            <div class="avatar">
                                @if (!string.IsNullOrWhiteSpace(post.User.Avatar))
                                {
                                    <img src="@post.User.Avatar" alt="@post.User.FullName" />
                                }
                                else
                                {
                                    <span>@GetInitials(post.User.FullName)</span>
                                }
                            </div>

                            <div class="post-card-body">
                                <div class="post-meta-row">
                                    <span class="post-author">@post.User.FullName</span>
                                    <span class="dot"></span>
                                    <span>@post.CreatedAt.ToString("dd MMM yyyy")</span>
                                    <span class="category-badge">@post.Category.Name</span>
                                </div>

                                <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id" class="post-title">
                                    @post.Title
                                </a>

                                <p class="post-excerpt">@GetExcerpt(post.Content)</p>

                                <div class="post-footer">
                                    <div class="post-metrics">
                                        <span class="metric likes">
                                            <i class="fa-solid fa-fire"></i>
                                            <span>@post.Likes.Count de xuat</span>
                                        </span>
                                        <span class="metric comments">
                                            <i class="fa-regular fa-comment-dots"></i>
                                            <span>@post.Comments.Count binh luan</span>
                                        </span>
                                        <span class="metric">
                                            <i class="fa-regular fa-eye"></i>
                                            <span>@post.ViewCount luot xem</span>
                                        </span>
                                    </div>

                                    <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id" class="btn btn-text">
                                        Mo chu de
                                        <i class="fa-solid fa-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </section>

    <aside class="forum-column forum-right">
        <div class="glass-panel side-panel">
            <div>
                <div class="panel-label">Tim kiem</div>
                <h2 class="section-heading">Loc nhanh noi dung</h2>
            </div>

            <form asp-action="Index" method="get" class="search-form">
                @if (currentCategory.HasValue)
                {
                    <input type="hidden" name="categoryId" value="@currentCategory" />
                }

                @if (!string.IsNullOrEmpty(currentSort))
                {
                    <input type="hidden" name="sortOrder" value="@currentSort" />
                }

                <div class="search-row">
                    <input type="text" name="searchString" value="@searchString" class="form-control" placeholder="Tieu de, noi dung, tu khoa..." />
                    <button type="submit" class="btn btn-primary search-submit" aria-label="Tim kiem">
                        <i class="fa-solid fa-arrow-right"></i>
                    </button>
                </div>
            </form>
        </div>
    </aside>
</div>
