@using System.Linq
@using ForumZenpace.Models
@model HomeIndexViewModel
@{
    ViewData["Title"] = "Bang tin";

    var posts = Model.Posts?.ToList() ?? new List<Post>();
    var categories = Model.Categories?.ToList() ?? new List<Category>();
    var friends = Model.Friends?.ToList() ?? new List<FriendSummaryViewModel>();
    var currentSort = (Model.CurrentSort ?? string.Empty).ToLowerInvariant();
    var searchString = Model.SearchString;
    var currentCategory = Model.CurrentCategoryId;
    var sortRoute = string.IsNullOrEmpty(currentSort) ? null : currentSort;
    var searchRoute = string.IsNullOrWhiteSpace(searchString) ? null : searchString;
    var canUseSocial = Model.CurrentUserId.HasValue;
    var ownStory = Model.CurrentUserStory;
    var currentUsername = User.Identity?.Name ?? "ban";

    string GetInitials(string? name, string? fallback = null)
    {
        var source = string.IsNullOrWhiteSpace(name) ? fallback : name;
        if (string.IsNullOrWhiteSpace(source))
        {
            return "?";
        }

        var parts = source.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1)
        {
            return parts[0][0].ToString().ToUpperInvariant();
        }

        return string.Concat(parts[0][0], parts[^1][0]).ToUpperInvariant();
    }

    string GetExcerpt(string? content)
    {
        return PostContentFormatter.ToExcerpt(content, 180);
    }
}

@if (canUseSocial)
{
    <div class="home-social-band animated-entry">
        <div class="home-social-add">
            <button type="button" class="glass-panel social-card social-card--add" data-open-friend-modal>
                <span class="social-card-icon">
                    <i class="fa-solid fa-user-plus"></i>
                </span>
                <span class="social-card-copy">
                    <strong>Them ban</strong>
                    <span>Mo popup tim kiem va gui loi moi ket ban realtime</span>
                </span>
            </button>
        </div>

        <div class="home-social-rail">
            <div class="social-friend-rail" data-friend-rail>
                <button type="button"
                        class="social-friend-nav social-friend-nav--prev"
                        data-friend-nav-prev
                        aria-label="Xem nhom ban truoc"
                        aria-controls="homeFriendList"
                        hidden>
                    <i class="fa-solid fa-chevron-left"></i>
                </button>

                <div id="homeFriendList" class="social-friend-list" data-friend-list>
                    @if (canUseSocial)
                    {
                        if (ownStory?.HasActiveStory == true && ownStory.LatestStoryId.HasValue)
                        {
                            <a asp-controller="Story"
                               asp-action="Viewer"
                               asp-route-id="@ownStory.LatestStoryId.Value"
                               class="glass-panel social-card social-card--friend social-card--story social-card--story-self"
                               title="Xem khoanh khac cua ban">
                                <span class="social-story-pill">@ownStory.ActiveStoryCount story</span>
                                <span class="social-avatar social-avatar--story is-own-story">
                                    <span>@GetInitials(currentUsername)</span>
                                </span>
                                <span class="social-card-copy">
                                    <strong>Story cua ban</strong>
                                    <span>Dang hien voi ban be</span>
                                </span>
                            </a>
                        }
                        else
                        {
                            <button type="button"
                                    class="glass-panel social-card social-card--friend social-card--story social-card--story-self"
                                    data-open-story-modal
                                    title="Dang khoanh khac moi">
                                <span class="social-story-pill is-create">Moi</span>
                                <span class="social-avatar social-avatar--story is-own-story is-create">
                                    <i class="fa-solid fa-plus"></i>
                                </span>
                                <span class="social-card-copy">
                                    <strong>Tao story</strong>
                                    <span>Dang khoanh khac trong 24 gio</span>
                                </span>
                            </button>
                        }
                    }

                    @if (friends.Any())
                    {
                        @foreach (var friend in friends)
                        {
                            var friendState = friend.IsMessageBlockedByViewer
                                ? "blocked-by-viewer"
                                : friend.IsMessageBlockedByOtherUser
                                    ? "blocked-by-other"
                                    : "connected";

                            var friendTitle = friend.HasActiveStory && friend.LatestStoryId.HasValue
                                ? $"Xem khoanh khac cua @{friend.Username}"
                                : friend.IsMessageBlockedByViewer
                                ? "Ban dang chan tin nhan voi nguoi nay."
                                : friend.IsMessageBlockedByOtherUser
                                    ? "Nguoi nay dang chan tin nhan voi ban."
                                    : $"Trang ca nhan cua @{friend.Username}";

                            <a asp-controller="@(friend.HasActiveStory && friend.LatestStoryId.HasValue ? "Story" : "Profile")"
                               asp-action="@(friend.HasActiveStory && friend.LatestStoryId.HasValue ? "Viewer" : "UserProfile")"
                               asp-route-id="@(friend.HasActiveStory && friend.LatestStoryId.HasValue ? friend.LatestStoryId : null)"
                               asp-route-username="@(friend.HasActiveStory && friend.LatestStoryId.HasValue ? null : friend.Username)"
                               class="glass-panel social-card social-card--friend @(friend.HasActiveStory ? "social-card--story" : string.Empty) @(friend.HasUnviewedStory ? "social-card--story-fresh" : string.Empty)"
                               data-friend-card
                               data-friend-user-id="@friend.UserId"
                               data-friend-username="@friend.Username"
                               data-friend-state="@friendState"
                               title="@friendTitle">
                                <span class="social-friend-badge @(friendState == "connected" ? "is-hidden" : string.Empty)"
                                      data-friend-status-badge
                                      aria-hidden="true">
                                    <i class="fa-solid @(friendState == "blocked-by-viewer" ? "fa-ban" : "fa-shield-halved")"></i>
                                </span>
                                @if (friend.HasActiveStory)
                                {
                                    <span class="social-story-pill">@friend.ActiveStoryCount story</span>
                                }

                                <span class="social-avatar social-avatar--story @(friend.HasActiveStory ? "has-story" : string.Empty)">
                                    @if (!string.IsNullOrWhiteSpace(friend.AvatarUrl))
                                    {
                                        <img src="@friend.AvatarUrl" alt="@friend.DisplayName" />
                                    }
                                    else
                                    {
                                        <span>@GetInitials(friend.DisplayName, friend.Username)</span>
                                    }
                                </span>
                                <span class="social-card-copy">
                                    <strong>@@@friend.Username</strong>
                                    @if (friend.HasActiveStory)
                                    {
                                        <span>@(friend.HasUnviewedStory ? "Chua xem" : "Da xem")</span>
                                    }
                                </span>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="glass-panel social-card social-card--empty" data-friend-empty>
                            <span class="social-card-icon">
                                <i class="fa-regular fa-user"></i>
                            </span>
                            <span class="social-card-copy">
                                <strong>Chua co ban</strong>
                                <span>Bat dau ket noi tu o Them ban</span>
                            </span>
                        </div>
                    }
                </div>

                <button type="button"
                        class="social-friend-nav social-friend-nav--next"
                        data-friend-nav-next
                        aria-label="Xem nhom ban tiep theo"
                        aria-controls="homeFriendList"
                        hidden>
                    <i class="fa-solid fa-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>
}

<div class="home-toolbar animated-entry">
    <div class="home-toolbar-main">
        <div class="feed-controls">
            <div class="segmented-control glass-panel">
                <a asp-action="Index"
                   asp-route-sortOrder="newest"
                   asp-route-categoryId="@currentCategory"
                   asp-route-searchString="@searchRoute"
                   class="btn @(string.IsNullOrEmpty(currentSort) || currentSort == "newest" ? "btn-primary" : "btn-text")">
                    Moi nhat
                </a>
                <a asp-action="Index"
                   asp-route-sortOrder="views"
                   asp-route-categoryId="@currentCategory"
                   asp-route-searchString="@searchRoute"
                   class="btn @(currentSort == "views" ? "btn-primary" : "btn-text")">
                    Xem nhieu
                </a>
                <a asp-action="Index"
                   asp-route-sortOrder="likes"
                   asp-route-categoryId="@currentCategory"
                   asp-route-searchString="@searchRoute"
                   class="btn @(currentSort == "likes" ? "btn-primary" : "btn-text")">
                    De xuat
                </a>
            </div>
        </div>
    </div>
</div>

@if (canUseSocial)
{
    <div class="social-modal" data-friend-modal hidden aria-hidden="true">
        <div class="social-modal-backdrop" data-close-friend-modal></div>
        <div class="surface social-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="friendModalTitle">
            <div class="social-modal-header">
                <div>
                    <div class="panel-label">Ket noi</div>
                    <h2 id="friendModalTitle" class="section-heading">Them ban moi</h2>
                    <p class="surface-subtitle">Nhap ten, username hoac email de tim thanh vien va gui loi moi ket ban realtime.</p>
                </div>
                <button type="button" class="profile-modal-close" aria-label="Dong popup" data-close-friend-modal>
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <div class="social-search-shell">
                <label class="field-label" for="friendSearchBox">Tim nguoi dung</label>
                <div class="social-search-row">
                    <input id="friendSearchBox"
                           type="text"
                           class="form-control"
                           placeholder="Nhap ten, username hoac email..."
                           data-friend-search-input />
                    <button type="button" class="btn btn-primary" data-friend-search-button>
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </button>
                </div>
                <div class="field-hint" data-friend-search-status>Hien thi goi y ket noi moi tu cong dong Zenpace.</div>
            </div>

            <div class="social-search-results" data-friend-search-results></div>
        </div>
    </div>
}

<div class="forum-page animated-entry">
    <aside class="forum-column forum-sidebar">
        <div class="glass-panel sidebar-panel">
            <div class="panel-label">Danh muc</div>

            <a asp-action="Index"
               asp-route-sortOrder="@sortRoute"
               asp-route-searchString="@searchRoute"
               class="sidebar-link @(!currentCategory.HasValue ? "active" : "")">
                <i class="fa-solid fa-layer-group"></i>
                <span>Tat ca</span>
            </a>

            @foreach (var category in categories)
            {
                <a asp-action="Index"
                   asp-route-categoryId="@category.Id"
                   asp-route-sortOrder="@sortRoute"
                   asp-route-searchString="@searchRoute"
                   class="sidebar-link @(currentCategory == category.Id ? "active" : "")">
                    <i class="fa-solid fa-hashtag"></i>
                    <span>@category.Name</span>
                </a>
            }
        </div>
    </aside>

    <section class="forum-column forum-main">
        @if (!posts.Any())
        {
            <div class="glass-panel empty-state">
                <div class="empty-icon">
                    <i class="fa-regular fa-message"></i>
                </div>
                <h2 class="section-heading">Chua co chu de nao</h2>
                <p class="muted">Thu thay doi bo loc, tim kiem lai, hoac bat dau mot bai viet moi de kich hoat bang tin.</p>
                <div>
                    <a asp-controller="Post" asp-action="Create" class="btn btn-primary">Tao chu de dau tien</a>
                </div>
            </div>
        }
        else
        {
            <div class="post-list">
                @foreach (var post in posts)
                {
                    <article class="glass-panel post-card">
                        <div class="post-card-header">
                            <a asp-controller="Profile"
                               asp-action="UserProfile"
                               asp-route-username="@post.User.Username"
                               class="avatar-link"
                               aria-label="Xem trang ca nhan cua @post.User.FullName">
                                <div class="avatar">
                                    @if (!string.IsNullOrWhiteSpace(post.User.Avatar))
                                    {
                                        <img src="@post.User.Avatar" alt="@post.User.FullName" />
                                    }
                                    else
                                    {
                                        <span>@GetInitials(post.User.FullName, post.User.Username)</span>
                                    }
                                </div>
                            </a>

                            <div class="post-card-body">
                                <div class="post-meta-row">
                                    <a asp-controller="Profile"
                                       asp-action="UserProfile"
                                       asp-route-username="@post.User.Username"
                                       class="post-author post-author-link">@post.User.FullName</a>
                                    <span class="dot"></span>
                                    <span>@post.CreatedAt.ToString("dd MMM yyyy")</span>
                                    <span class="category-badge">@post.Category.Name</span>
                                </div>

                                <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id" class="post-title">
                                    @post.Title
                                </a>

                                <p class="post-excerpt">@GetExcerpt(post.Content)</p>

                                <div class="post-footer">
                                    <div class="post-metrics">
                                        <span class="metric likes">
                                            <i class="fa-solid fa-fire"></i>
                                            <span>@post.Likes.Count de xuat</span>
                                        </span>
                                        <span class="metric comments">
                                            <i class="fa-regular fa-comment-dots"></i>
                                            <span>@post.Comments.Count binh luan</span>
                                        </span>
                                        <span class="metric">
                                            <i class="fa-regular fa-eye"></i>
                                            <span>@post.ViewCount luot xem</span>
                                        </span>
                                    </div>

                                    <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id" class="btn btn-text">
                                        Mo chu de
                                        <i class="fa-solid fa-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </section>

    <aside class="forum-column forum-right">
        <div class="glass-panel side-panel">
            <div>
                <div class="panel-label">Tim kiem</div>
                <h2 class="section-heading">Loc nhanh noi dung</h2>
            </div>

            <form asp-action="Index" method="get" class="search-form">
                @if (currentCategory.HasValue)
                {
                    <input type="hidden" name="categoryId" value="@currentCategory" />
                }

                @if (!string.IsNullOrEmpty(currentSort))
                {
                    <input type="hidden" name="sortOrder" value="@currentSort" />
                }

                <div class="search-row">
                    <input type="text" name="searchString" value="@searchString" class="form-control" placeholder="Tieu de, noi dung, tu khoa..." />
                    <button type="submit" class="btn btn-primary search-submit" aria-label="Tim kiem">
                        <i class="fa-solid fa-arrow-right"></i>
                    </button>
                </div>
            </form>
        </div>
    </aside>
</div>
