@using System.Linq
@using ForumZenpace.Models
@using Microsoft.EntityFrameworkCore
@inject ForumDbContext DbContext
@model HomeIndexViewModel
@{
    ViewData["Title"] = "Bảng tin";

    var posts = Model.Posts?.ToList() ?? new List<Post>();
    var categories = Model.Categories?.ToList() ?? new List<Category>();
    var friends = Model.Friends?.ToList() ?? new List<FriendSummaryViewModel>();
    var currentSort = (Model.CurrentSort ?? string.Empty).ToLowerInvariant();
    var searchString = Model.SearchString;
    var currentCategory = Model.CurrentCategoryId;
    var sortRoute = string.IsNullOrEmpty(currentSort) ? null : currentSort;
    var searchRoute = string.IsNullOrWhiteSpace(searchString) ? null : searchString;
    var canUseSocial = Model.CurrentUserId.HasValue;
    var ownStory = Model.CurrentUserStory;
    var currentUsername = User.Identity?.Name ?? "bạn";
    var currentUserAvatar = Model.CurrentUserId.HasValue 
        ? await DbContext.Users.Where(u => u.Id == Model.CurrentUserId.Value).Select(u => u.Avatar).FirstOrDefaultAsync() 
        : null;
    var currentUserStoryCoverStyle = !string.IsNullOrWhiteSpace(currentUserAvatar)
        ? $"--story-cover-image: url('{Url.Content("~" + currentUserAvatar)}');"
        : null;

    string GetInitials(string? name, string? fallback = null)
    {
        var source = string.IsNullOrWhiteSpace(name) ? fallback : name;
        if (string.IsNullOrWhiteSpace(source))
        {
            return "?";
        }

        var parts = source.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1)
        {
            return parts[0][0].ToString().ToUpperInvariant();
        }

        return string.Concat(parts[0][0], parts[^1][0]).ToUpperInvariant();
    }

    string GetExcerpt(string? content)
    {
        return PostContentFormatter.ToExcerpt(content, 180);
    }
}

@if (canUseSocial)
{
    <style>
        /* === STORY / SOCIAL RAIL (facebook-like vertical story cards) === */
        .home-social-band {
            width: 100%;
            max-width: none;
            margin: 0 0 var(--space-4) 0;
            min-width: 0;
        }
        .home-social-band .home-social-rail {
            width: 100%;
            min-width: 0;
            display: block;
            padding: 16px 18px;
            overflow: hidden;
            border-radius: 18px;
                background: linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.012)), rgba(10, 12, 33, 0.76);
                border: 1px solid rgba(255, 255, 255, 0.1);
                box-shadow: var(--shadow-soft);
            backdrop-filter: var(--blur-panel);
            -webkit-backdrop-filter: var(--blur-panel);
        }
        .home-social-band .social-friend-rail {
            position: relative;
            width: 100%;
            min-width: 0;
            overflow: hidden;
        }
        .home-social-band .social-friend-list {
            display: flex;
            flex-wrap: nowrap;
            align-items: stretch;
            gap: 14px;
            overflow-x: auto;
            overflow-y: hidden;
            width: 100%;
            min-width: 0;
            padding: 4px 2px 8px;
            scroll-snap-type: x mandatory;
            scroll-padding-inline: 2px;
            scrollbar-width: none;
            -ms-overflow-style: none;
            cursor: grab;
            user-select: none;
            overscroll-behavior-x: contain;
            -webkit-overflow-scrolling: touch;
            scroll-behavior: smooth;
        }
        .home-social-band .social-friend-list.is-dragging {
            cursor: grabbing;
            scroll-snap-type: none;
        }
        .home-social-band .social-friend-list::-webkit-scrollbar {
            display: none;
        }
        .home-social-band .social-story-card {
            position: relative;
            width: 112px;
            min-width: 112px;
            height: 198px;
            padding: 0;
            display: block;
            border-radius: 18px;
            overflow: hidden;
            scroll-snap-align: start;
            scroll-snap-stop: always;
            border: 1px solid rgba(255, 255, 255, 0.12);
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.01)),
                rgba(31, 24, 62, 0.82);
            box-shadow: 0 14px 28px rgba(0, 0, 0, 0.22);
            transform-origin: center;
            transition:
                transform 180ms ease,
                box-shadow 180ms ease,
                border-color 180ms ease;
        }
        .home-social-band .social-story-card:hover {
            transform: translateY(-3px) scale(1.02);
            border-color: rgba(255, 255, 255, 0.2);
            box-shadow:
                0 24px 40px rgba(2, 8, 23, 0.3),
                0 10px 24px rgba(15, 23, 42, 0.2);
        }
        .home-social-band .social-story-card:focus-visible {
            outline: 2px solid rgba(147, 197, 253, 0.9);
            outline-offset: 3px;
        }
        .home-social-band .social-story-card__media {
            position: relative;
            width: 100%;
            height: 100%;
            display: block;
        }
        .home-social-band .social-story-card__cover,
        .home-social-band .social-story-card__overlay {
            position: absolute;
            inset: 0;
        }
        .home-social-band .social-story-card__cover {
            background:
                radial-gradient(circle at 28% 18%, rgba(255, 255, 255, 0.2), transparent 34%),
                linear-gradient(180deg, rgba(30, 41, 59, 0.22) 0%, rgba(15, 23, 42, 0.82) 100%),
                linear-gradient(160deg, #355c7d 0%, #6c5b7b 45%, #c06c84 100%);
            background-position: center;
            background-size: cover;
            transform: scale(1.01);
            transition: transform 180ms ease;
        }
        .home-social-band .social-story-card__media.has-cover .social-story-card__cover {
            background-image:
                linear-gradient(180deg, rgba(15, 23, 42, 0.06) 0%, rgba(15, 23, 42, 0.56) 100%),
                var(--story-cover-image);
        }
        .home-social-band .social-story-card:hover .social-story-card__cover {
            transform: scale(1.015);
        }
        .home-social-band .social-story-card__overlay {
            background:
                linear-gradient(180deg, rgba(12, 20, 33, 0.08) 0%, rgba(12, 20, 33, 0.26) 52%, rgba(12, 20, 33, 0.82) 100%);
            transform: none !important;
            transition: none !important;
        }
        .home-social-band .social-story-card__avatar-frame {
            position: absolute;
            top: 12px;
            left: 12px;
            width: 42px;
            height: 42px;
            padding: 3px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            z-index: 2;
            background: rgba(148, 163, 184, 0.6);
            box-shadow: 0 8px 20px rgba(15, 23, 42, 0.28);
        }
        .home-social-band .social-story-card__avatar-frame--fresh {
            background: linear-gradient(135deg, #1877f2, #60a5fa);
        }
        .home-social-band .social-story-card__avatar-frame--seen {
            background: rgba(255, 255, 255, 0.42);
        }
        .home-social-band .social-avatar.social-avatar--story {
            width: 100%;
            height: 100%;
            border-radius: 999px;
            border: 2px solid rgba(255, 255, 255, 0.94);
            background: rgba(15, 23, 42, 0.82);
            overflow: hidden;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 0.95rem;
            font-weight: 800;
        }
        .home-social-band .social-avatar.social-avatar--story img,
        .home-social-band .social-avatar.social-avatar--story > span {
            width: 100%;
            height: 100%;
            border-radius: inherit;
            object-fit: cover;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        .home-social-band .social-story-card__presence {
            position: absolute;
            top: 40px;
            left: 42px;
            width: 12px;
            height: 12px;
            border-width: 2px;
            z-index: 3;
        }
        .home-social-band .social-story-card__name {
            position: absolute;
            right: 12px;
            bottom: 12px;
            left: 12px;
            z-index: 2;
            font-size: 0.83rem;
            font-weight: 800;
            line-height: 1.2;
            color: #fff;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            text-shadow: 0 2px 8px rgba(15, 23, 42, 0.8);
        }
        .home-social-band .social-story-pill {
            top: 12px;
            right: 12px;
            z-index: 3;
            min-height: 24px;
            padding: 0 9px;
            border-radius: 999px;
            background: rgba(15, 23, 42, 0.64);
            border: 1px solid rgba(255, 255, 255, 0.14);
            color: rgba(255, 255, 255, 0.96);
            font-size: 0.68rem;
            font-weight: 800;
            backdrop-filter: blur(10px);
        }
        .home-social-band .social-story-card--create {
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.015)),
                rgba(31, 24, 62, 0.86);
            border-color: rgba(255, 255, 255, 0.12);
        }
        .home-social-band .social-story-card--create .social-story-card__cover {
            background:
                radial-gradient(circle at 20% 12%, rgba(255, 255, 255, 0.14), transparent 32%),
                linear-gradient(160deg, rgba(255, 82, 210, 0.18) 0%, rgba(155, 118, 255, 0.2) 48%, rgba(121, 201, 255, 0.16) 100%);
        }
        .home-social-band .social-story-card--create .social-story-card__media.has-cover .social-story-card__cover {
            background-image:
                linear-gradient(180deg, rgba(12, 20, 33, 0.02) 0%, rgba(12, 20, 33, 0.18) 100%),
                var(--story-cover-image);
            background-position: center;
            background-size: cover;
        }
        .home-social-band .social-story-card--create .social-story-card__overlay {
            background: linear-gradient(180deg, rgba(12, 20, 33, 0.02) 0%, rgba(12, 20, 33, 0.08) 56%, rgba(12, 20, 33, 0.2) 100%);
        }
        .home-social-band .social-story-card__footer--create {
            position: absolute;
            right: 0;
            bottom: 0;
            left: 0;
            z-index: 2;
            min-height: 64px;
            padding: 18px 12px 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.015)),
                rgba(24, 19, 50, 0.96);
            border-top: 1px solid rgba(255, 255, 255, 0.06);
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
        }
        .home-social-band .social-story-card__footer--create .social-story-card__name {
            position: static;
            color: rgba(245, 247, 255, 0.96);
            text-shadow: 0 2px 8px rgba(10, 14, 34, 0.45);
            text-align: center;
        }
        .home-social-band .social-story-card__plus {
            position: absolute;
            top: -18px;
            left: 50%;
            width: 36px;
            height: 36px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            transform: translateX(-50%);
            background: var(--primary-gradient);
            color: #fff;
            border: 4px solid rgba(27, 20, 58, 0.96);
            box-shadow:
                0 10px 20px rgba(58, 39, 116, 0.28),
                0 0 18px rgba(241, 110, 224, 0.18),
                0 0 24px rgba(121, 201, 255, 0.14);
        }
        .home-social-band .social-story-card--utility .social-story-card__cover,
        .home-social-band .social-story-card--empty .social-story-card__cover {
            background:
                radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.12), transparent 32%),
                linear-gradient(160deg, rgba(88, 41, 157, 0.8) 0%, rgba(53, 36, 114, 0.92) 52%, rgba(17, 24, 39, 0.98) 100%);
        }
        .home-social-band .social-story-card--empty .social-story-card__cover {
            background:
                linear-gradient(160deg, rgba(55, 43, 104, 0.92), rgba(18, 16, 42, 0.96));
        }
        .home-social-band .social-story-card__utility-icon {
            position: absolute;
            top: 18px;
            left: 18px;
            width: 42px;
            height: 42px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            z-index: 2;
            background: rgba(255, 255, 255, 0.16);
            border: 1px solid rgba(255, 255, 255, 0.24);
            color: #fff;
            font-size: 1rem;
            box-shadow: 0 10px 22px rgba(15, 23, 42, 0.22);
        }
        .home-social-band .social-story-card--empty {
            border-style: dashed;
            border-color: rgba(255, 255, 255, 0.18);
        }
        .home-social-band .social-story-card--empty .social-story-card__name {
            white-space: normal;
        }
        .home-social-band .social-friend-badge {
            top: 12px;
            right: 12px;
            left: auto;
            z-index: 3;
        }
        .home-social-band .social-friend-nav {
            width: 38px;
            height: 38px;
        }
        @@media (max-width: 991.98px) {
            .home-social-band .social-story-card {
                width: 108px;
                min-width: 108px;
                height: 192px;
            }
        }
        @@media (max-width: 767.98px) {
            .home-social-band .home-social-rail {
                padding: 14px 12px;
                border-radius: 16px;
            }
            .home-social-band .social-friend-list {
                padding-inline: 2px;
                gap: 12px;
            }
            .home-social-band .social-story-card {
                width: 102px;
                min-width: 102px;
                height: 184px;
            }
            .home-social-band .social-friend-nav {
                display: none;
            }
        }

        /* === POST CARD === */
        .post-card {
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.015)),
                var(--panel-bg-strong) !important;
            border: 1px solid var(--panel-border) !important;
            border-radius: 12px !important;
            box-shadow: 0 14px 28px rgba(0, 0, 0, 0.22) !important;
            transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease !important;
        }
        .post-card:hover {
            transform: translateY(-2px) !important;
            box-shadow: var(--shadow-hover) !important;
            border-color: var(--panel-border-strong) !important;
        }
        /* Post title — 2 dòng clamp, không bị display:block phá clamp */
        .post-title {
            font-size: 1.1rem !important;
            font-weight: 700 !important;
            color: rgba(255,255,255,0.97) !important;
            line-height: 1.35 !important;
            text-shadow: 0 1px 2px rgba(0,0,0,0.4);
            display: -webkit-box !important;
            -webkit-box-orient: vertical !important;
            -webkit-line-clamp: 2 !important;
            overflow: hidden !important;
            white-space: normal !important;
        }
        .post-excerpt { color: rgba(255,255,255,0.72) !important; font-size: 0.875rem !important; }
        .post-metrics { display: flex; gap: 16px; }
        .metric { font-weight: 600; font-size: 0.875rem; color: var(--text-secondary); display: inline-flex; gap: 6px; align-items: center; }
        .metric.likes { color: var(--accent-pink); }
        .metric.comments { color: var(--accent-purple); }

        /* === SIDEBAR === */
        .sidebar-link {
            color: var(--text-secondary) !important;
        }
        .sidebar-link:hover:not(.active) {
            background: rgba(255,255,255,0.05) !important;
            border-color: var(--panel-border) !important;
            color: var(--text-primary) !important;
            transform: translateX(3px) !important;
        }
        .sidebar-link.active {
            color: #fff !important;
            background: linear-gradient(135deg, rgba(255, 82, 210, 0.18), rgba(155, 118, 255, 0.18), rgba(121, 201, 255, 0.14)) !important;
            border: 1px solid rgba(160, 133, 255, 0.32) !important;
            box-shadow:
                0 0 16px rgba(160, 85, 255, 0.14),
                inset 0 1px 0 rgba(255, 255, 255, 0.08) !important;
        }

        /* === BACKGROUND WAVES === */
        .abstract-background__wave { opacity: 0.12 !important; }
    </style>
    <div class="home-social-band animated-entry">
        <div class="home-social-rail">
            <div class="social-friend-rail" data-friend-rail>
                <button type="button"
                        class="social-friend-nav social-friend-nav--prev"
                        data-friend-nav-prev
                        aria-label="Xem nhóm bạn trước"
                        aria-controls="homeFriendList"
                        hidden>
                    <i class="fa-solid fa-chevron-left"></i>
                </button>

                <div id="homeFriendList" class="social-friend-list" data-friend-list>
                    @if (canUseSocial)
                    {
                        <button type="button"
                                class="glass-panel social-card social-card--friend social-card--story social-card--story-self social-story-card social-story-card--create"
                                data-open-story-modal
                                title="Tạo story mới">
                            <span class="social-story-card__media @(string.IsNullOrWhiteSpace(currentUserAvatar) ? string.Empty : "has-cover")"
                                  style="@currentUserStoryCoverStyle">
                                <span class="social-story-card__cover" aria-hidden="true"></span>
                                <span class="social-story-card__overlay" aria-hidden="true"></span>
                                <span class="social-story-card__footer social-story-card__footer--create">
                                    <span class="social-story-card__plus" aria-hidden="true">
                                        <i class="fa-solid fa-plus"></i>
                                    </span>
                                    <span class="social-story-card__name" title="Tạo story">Tạo story</span>
                                </span>
                            </span>
                        </button>

                        @if (ownStory?.HasActiveStory == true && ownStory.LatestStoryId.HasValue)
                        {
                            <a asp-controller="Story"
                               asp-action="Viewer"
                               asp-route-id="@ownStory.LatestStoryId.Value"
                               class="glass-panel social-card social-card--friend social-card--story social-card--story-self social-story-card social-story-card--fresh"
                               title="Xem story của bạn">
                                <span class="social-story-card__media @(string.IsNullOrWhiteSpace(currentUserAvatar) ? string.Empty : "has-cover")"
                                      style="@currentUserStoryCoverStyle">
                                    <span class="social-story-card__cover" aria-hidden="true"></span>
                                    <span class="social-story-card__overlay" aria-hidden="true"></span>
                                    <span class="social-story-pill">Bạn</span>
                                    <span class="social-story-card__avatar-frame social-story-card__avatar-frame--fresh">
                                        <span class="social-avatar social-avatar--story is-own-story">
                                            @if (!string.IsNullOrWhiteSpace(currentUserAvatar))
                                            {
                                                <img src="@Url.Content("~" + currentUserAvatar)" alt="Story của bạn" />
                                            }
                                            else
                                            {
                                                <span>@GetInitials(currentUsername)</span>
                                            }
                                        </span>
                                    </span>
                                    <span class="social-story-card__name" title="Story của bạn">Story của bạn</span>
                                </span>
                            </a>
                        }

                        <button type="button"
                                class="glass-panel social-card social-card--friend social-card--add social-story-card social-story-card--utility"
                                data-open-friend-modal
                                title="Tìm và thêm bạn bè">
                            <span class="social-story-card__media">
                                <span class="social-story-card__cover" aria-hidden="true"></span>
                                <span class="social-story-card__overlay" aria-hidden="true"></span>
                                <span class="social-story-card__utility-icon" aria-hidden="true">
                                    <i class="fa-solid fa-user-plus"></i>
                                </span>
                                <span class="social-story-card__name" title="Thêm bạn">Thêm bạn</span>
                            </span>
                        </button>
                    }

                    @if (friends.Any())
                    {
                        @foreach (var friend in friends)
                        {
                            var friendState = friend.IsMessageBlockedByViewer
                                ? "blocked-by-viewer"
                                : friend.IsMessageBlockedByOtherUser
                                    ? "blocked-by-other"
                                    : "connected";

                            var friendTitle = friend.HasActiveStory && friend.LatestStoryId.HasValue
                                ? $"Xem khoảnh khắc của @{friend.Username}"
                                : friend.IsMessageBlockedByViewer
                                ? "Bạn đang chặn tin nhắn với người này."
                                : friend.IsMessageBlockedByOtherUser
                                    ? "Người này đang chặn tin nhắn với bạn."
                                    : $"Trang cá nhân của @{friend.Username}";
                            var friendCoverStyle = !string.IsNullOrWhiteSpace(friend.AvatarUrl)
                                ? $"--story-cover-image: url('{Url.Content("~" + friend.AvatarUrl)}');"
                                : null;
                            var friendStoryCardModifier = friend.HasActiveStory
                                ? (friend.HasUnviewedStory ? "social-story-card--fresh" : "social-story-card--seen")
                                : "social-story-card--idle";

                            <a asp-controller="@(friend.HasActiveStory && friend.LatestStoryId.HasValue ? "Story" : "Profile")"
                               asp-action="@(friend.HasActiveStory && friend.LatestStoryId.HasValue ? "Viewer" : "UserProfile")"
                               asp-route-id="@(friend.HasActiveStory && friend.LatestStoryId.HasValue ? friend.LatestStoryId : null)"
                               asp-route-username="@(friend.HasActiveStory && friend.LatestStoryId.HasValue ? null : friend.Username)"
                               class="glass-panel social-card social-card--friend @(friend.HasActiveStory ? "social-card--story" : string.Empty) @(friend.HasUnviewedStory ? "social-card--story-fresh" : string.Empty) social-story-card @friendStoryCardModifier"
                               data-friend-card
                               data-friend-user-id="@friend.UserId"
                               data-friend-username="@friend.Username"
                               data-friend-state="@friendState"
                               title="@friendTitle">
                                <span class="social-story-card__media @(string.IsNullOrWhiteSpace(friend.AvatarUrl) ? string.Empty : "has-cover")"
                                      style="@friendCoverStyle">
                                    <span class="social-story-card__cover" aria-hidden="true"></span>
                                    <span class="social-story-card__overlay" aria-hidden="true"></span>
                                    <span class="social-friend-badge @(friendState == "connected" ? "is-hidden" : string.Empty)"
                                          data-friend-status-badge
                                          aria-hidden="true">
                                        <i class="fa-solid @(friendState == "blocked-by-viewer" ? "fa-ban" : "fa-shield-halved")"></i>
                                    </span>
                                    @if (friend.HasActiveStory)
                                    {
                                        <span class="social-story-pill">@(friend.HasUnviewedStory ? "Chưa xem" : "Đã xem")</span>
                                    }
                                    <span class="social-story-card__avatar-frame @(friend.HasActiveStory && friend.HasUnviewedStory ? "social-story-card__avatar-frame--fresh" : "social-story-card__avatar-frame--seen")">
                                        <span class="social-avatar social-avatar--story @(friend.HasActiveStory ? "has-story" : string.Empty)">
                                            @if (!string.IsNullOrWhiteSpace(friend.AvatarUrl))
                                            {
                                                <img src="@Url.Content("~" + friend.AvatarUrl)" alt="@friend.DisplayName" />
                                            }
                                            else
                                            {
                                                <span>@GetInitials(friend.DisplayName, friend.Username)</span>
                                            }
                                        </span>
                                    </span>
                                    <span class="presence-dot social-story-card__presence" data-presence-user-id="@friend.UserId"></span>
                                    <span class="social-story-card__name" title="@friend.Username">@@@friend.Username</span>
                                </span>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="glass-panel social-card social-card--empty social-story-card social-story-card--empty" data-friend-empty>
                            <span class="social-story-card__media">
                                <span class="social-story-card__cover" aria-hidden="true"></span>
                                <span class="social-story-card__overlay" aria-hidden="true"></span>
                                <span class="social-story-card__utility-icon" aria-hidden="true">
                                    <i class="fa-regular fa-user"></i>
                                </span>
                                <span class="social-story-card__name" title="Chưa có bạn">Chưa có bạn</span>
                            </span>
                        </div>
                    }
                </div>

                <button type="button"
                        class="social-friend-nav social-friend-nav--next"
                        data-friend-nav-next
                        aria-label="Xem nhóm bạn tiếp theo"
                        aria-controls="homeFriendList"
                        hidden>
                    <i class="fa-solid fa-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>
}

<div class="home-toolbar animated-entry">
    <div class="home-toolbar-main">
        <div class="feed-controls">
            <div class="segmented-control glass-panel">
                <a asp-action="Index"
                   asp-route-sortOrder="recommended"
                   asp-route-categoryId="@currentCategory"
                   asp-route-searchString="@searchRoute"
                   class="btn @(currentSort == "recommended" ? "btn-primary" : "btn-text")">
                    <i class="fa-solid fa-wand-magic-sparkles"></i> Đề xuất
                </a>
                <a asp-action="Index"
                   asp-route-sortOrder="newest"
                   asp-route-categoryId="@currentCategory"
                   asp-route-searchString="@searchRoute"
                   class="btn @(currentSort == "newest" ? "btn-primary" : "btn-text")">
                    Mới nhất
                </a>
                <a asp-action="Index"
                   asp-route-sortOrder="views"
                   asp-route-categoryId="@currentCategory"
                   asp-route-searchString="@searchRoute"
                   class="btn @(currentSort == "views" ? "btn-primary" : "btn-text")">
                    Xem nhiều
                </a>
                <a asp-action="Index"
                   asp-route-sortOrder="likes"
                   asp-route-categoryId="@currentCategory"
                   asp-route-searchString="@searchRoute"
                   class="btn @(currentSort == "likes" ? "btn-primary" : "btn-text")">
                    Yêu thích
                </a>
            </div>
        </div>
    </div>
</div>

@if (canUseSocial)
{
    <div class="social-modal" data-friend-modal hidden aria-hidden="true">
        <div class="social-modal-backdrop" data-close-friend-modal></div>
        <div class="surface social-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="friendModalTitle">
            <div class="social-modal-header">
                <div>
                    <div class="panel-label">Kết nối</div>
                    <h2 id="friendModalTitle" class="section-heading">Thêm bạn mới</h2>
                    <p class="surface-subtitle">Nhập tên, username hoặc email để tìm thành viên và gửi lời mời kết bạn realtime.</p>
                </div>
                <button type="button" class="profile-modal-close" aria-label="Dong popup" data-close-friend-modal>
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <div class="social-search-shell">
                <label class="field-label" for="friendSearchBox">Tìm người dùng</label>
                <div class="social-search-row">
                    <input id="friendSearchBox"
                           type="text"
                           class="form-control"
                           placeholder="Nhập tên, username hoặc email..."
                           data-friend-search-input />
                    <button type="button" class="btn btn-primary" data-friend-search-button>
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </button>
                </div>
                <div class="field-hint" data-friend-search-status>Hiển thị gợi ý kết nối mới từ cộng đồng Zenpace.</div>
            </div>

            <div class="social-search-results" data-friend-search-results></div>
        </div>
    </div>
}

<div class="forum-page animated-entry">
    <aside class="forum-column forum-sidebar">
        <div class="glass-panel sidebar-panel">
            <div class="panel-label">Danh mục</div>

            <a asp-action="Index"
               asp-route-sortOrder="@sortRoute"
               asp-route-searchString="@searchRoute"
               class="sidebar-link @(!currentCategory.HasValue ? "active" : "")">
                <i class="fa-solid fa-layer-group"></i>
                <span>Tất cả</span>
            </a>

            @foreach (var category in categories)
            {
                <a asp-action="Index"
                   asp-route-categoryId="@category.Id"
                   asp-route-sortOrder="@sortRoute"
                   asp-route-searchString="@searchRoute"
                   class="sidebar-link @(currentCategory == category.Id ? "active" : "")">
                    <i class="fa-solid fa-hashtag"></i>
                    <span>@category.Name</span>
                </a>
            }
        </div>
    </aside>

    <section class="forum-column forum-main">
        @if (!posts.Any())
        {
            <div class="glass-panel empty-state">
                <div class="empty-icon">
                    <i class="fa-regular fa-message"></i>
                </div>
                <h2 class="section-heading">Chưa có chủ đề nào</h2>
                <p class="muted">Thử thay đổi bộ lọc, tìm kiếm lại, hoặc bắt đầu một bài viết mới để kích hoạt bảng tin.</p>
                <div>
                    <a asp-controller="Post" asp-action="Create" class="btn btn-primary">Tạo chủ đề đầu tiên</a>
                </div>
            </div>
        }
        else
        {
            <div class="post-list">
                @{
                    var postIndex = 0;
                    var insertAfter = Model.SuggestionInsertAfterPost;
                    var hasSuggestions = canUseSocial && Model.SuggestedFriends.Any();
                    var suggestionsRendered = false;
                }

                @foreach (var post in posts)
                {
                    postIndex++;
                    <article class="glass-panel post-card">
                        <div class="post-card-header">
                            <a asp-controller="Profile"
                               asp-action="UserProfile"
                               asp-route-username="@post.User.Username"
                               class="avatar-link"
                               aria-label="Xem trang cá nhân của @post.User.FullName">
                                <div class="avatar">
                                    @if (!string.IsNullOrWhiteSpace(post.User.Avatar))
                                    {
                                        <img src="@Url.Content("~" + post.User.Avatar)" alt="@post.User.FullName" />
                                    }
                                    else
                                    {
                                        <span>@GetInitials(post.User.FullName, post.User.Username)</span>
                                    }
                                </div>
                                <span class="presence-dot" data-presence-user-id="@post.User.Id"></span>
                            </a>

                            <div class="post-card-body">
                                <div class="post-meta-row">
                                    <a asp-controller="Profile"
                                       asp-action="UserProfile"
                                       asp-route-username="@post.User.Username"
                                       class="post-author post-author-link">@post.User.FullName</a>
                                    <span class="dot"></span>
                                    <span>@post.CreatedAt.ToString("dd MMM yyyy")</span>
                                    <span class="category-badge">@post.Category.Name</span>
                                </div>

                                <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id" class="post-title">
                                    @post.Title
                                </a>

                                <p class="post-excerpt">@GetExcerpt(post.Content)</p>

                                <div class="post-footer">
                                    <div class="post-metrics">
                                        <span class="metric likes">
                                            <i class="fa-solid fa-fire"></i>
                                            <span>@post.Likes.Count đề xuất</span>
                                        </span>
                                        <span class="metric comments">
                                            <i class="fa-regular fa-comment-dots"></i>
                                            <span>@post.Comments.Count bình luận</span>
                                        </span>
                                        <span class="metric">
                                            <i class="fa-regular fa-eye"></i>
                                            <span>@post.ViewCount lượt xem</span>
                                        </span>
                                    </div>

                                    <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id" class="btn btn-text">
                                        Mở chủ đề
                                        <i class="fa-solid fa-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </article>

                    @if (hasSuggestions && !suggestionsRendered && postIndex % insertAfter == 0)
                    {
                        suggestionsRendered = true;
                        <div class="feed-suggestion-block glass-panel" data-feed-suggestion-block>
                            <div class="feed-suggestion-header">
                                <span class="feed-suggestion-title"><i class="fa-solid fa-user-group"></i> Những người bạn có thể biết</span>
                                <button type="button" class="btn btn-text feed-suggestion-dismiss" data-dismiss-suggestion title="Ẩn gợi ý"><i class="fa-solid fa-xmark"></i></button>
                            </div>
                            <div class="feed-suggestion-rail" data-feed-suggestion-rail>
                                @foreach (var s in Model.SuggestedFriends)
                                {
                                    <div class="feed-suggestion-card" data-suggestion-user-id="@s.UserId">
                                        <button type="button" class="feed-suggestion-dismiss-single" data-dismiss-single title="Ẩn">
                                            <i class="fa-solid fa-xmark"></i>
                                        </button>
                                        <a href="/Profile/user/@s.Username" class="feed-suggestion-avatar-link">
                                            @if (!string.IsNullOrWhiteSpace(s.AvatarUrl))
                                            {
                                                <img src="@Url.Content("~" + s.AvatarUrl)" alt="@s.DisplayName" class="feed-suggestion-avatar" />
                                            }
                                            else
                                            {
                                                <div class="feed-suggestion-avatar feed-suggestion-initials">
                                                    @GetInitials(s.DisplayName, s.Username)
                                                </div>
                                            }
                                        </a>
                                        <a href="/Profile/user/@s.Username" class="feed-suggestion-name">@s.DisplayName</a>
                                        @if (!string.IsNullOrWhiteSpace(s.ActionLabel) && s.ActionLabel.Contains("chung"))
                                        {
                                            <span class="feed-suggestion-mutual"><i class="fa-solid fa-users"></i> @s.ActionLabel</span>
                                        }
                                        else
                                        {
                                            <span class="feed-suggestion-mutual"><i class="fa-solid fa-user"></i> Người dùng Zenpace</span>
                                        }
                                        <button type="button"
                                                class="btn btn-primary feed-suggestion-add"
                                                data-feed-add-friend
                                                data-target-user-id="@s.UserId">
                                            <i class="fa-solid fa-user-plus"></i>
                                            <span>Thêm bạn bè</span>
                                        </button>
                                    </div>
                                }
                            </div>
                            <a href="#" class="feed-suggestion-see-all" data-open-friend-modal>Xem tất cả</a>
                        </div>
                    }
                }

                @* If fewer posts than insertAfter threshold, show suggestions at the end *@
                @if (hasSuggestions && !suggestionsRendered)
                {
                    <div class="feed-suggestion-block glass-panel" data-feed-suggestion-block>
                        <div class="feed-suggestion-header">
                            <span class="feed-suggestion-title"><i class="fa-solid fa-user-group"></i> Những người bạn có thể biết</span>
                            <button type="button" class="btn btn-text feed-suggestion-dismiss" data-dismiss-suggestion title="Ẩn gợi ý"><i class="fa-solid fa-xmark"></i></button>
                        </div>
                        <div class="feed-suggestion-rail" data-feed-suggestion-rail>
                            @foreach (var s in Model.SuggestedFriends)
                            {
                                <div class="feed-suggestion-card" data-suggestion-user-id="@s.UserId">
                                    <button type="button" class="feed-suggestion-dismiss-single" data-dismiss-single title="Ẩn">
                                        <i class="fa-solid fa-xmark"></i>
                                    </button>
                                    <a href="/Profile/user/@s.Username" class="feed-suggestion-avatar-link">
                                        @if (!string.IsNullOrWhiteSpace(s.AvatarUrl))
                                        {
                                            <img src="@Url.Content("~" + s.AvatarUrl)" alt="@s.DisplayName" class="feed-suggestion-avatar" />
                                        }
                                        else
                                        {
                                            <div class="feed-suggestion-avatar feed-suggestion-initials">
                                                @GetInitials(s.DisplayName, s.Username)
                                            </div>
                                        }
                                    </a>
                                    <a href="/Profile/user/@s.Username" class="feed-suggestion-name">@s.DisplayName</a>
                                    @if (!string.IsNullOrWhiteSpace(s.ActionLabel) && s.ActionLabel.Contains("chung"))
                                    {
                                        <span class="feed-suggestion-mutual"><i class="fa-solid fa-users"></i> @s.ActionLabel</span>
                                    }
                                    else
                                    {
                                        <span class="feed-suggestion-mutual"><i class="fa-solid fa-user"></i> Người dùng Zenpace</span>
                                    }
                                    <button type="button"
                                            class="btn btn-primary feed-suggestion-add"
                                            data-feed-add-friend
                                            data-target-user-id="@s.UserId">
                                        <i class="fa-solid fa-user-plus"></i>
                                        <span>Thêm bạn bè</span>
                                    </button>
                                </div>
                            }
                        </div>
                        <a href="#" class="feed-suggestion-see-all" data-open-friend-modal>Xem tất cả</a>
                    </div>
                }
            </div>

        }
    </section>

    <aside class="forum-column forum-right">
        <div class="glass-panel side-panel">
            <div>
                <div class="panel-label">Tìm kiếm</div>
                <h2 class="section-heading">Lọc nhanh nội dung</h2>
            </div>

            <form asp-action="Index" method="get" class="search-form">
                @if (currentCategory.HasValue)
                {
                    <input type="hidden" name="categoryId" value="@currentCategory" />
                }

                @if (!string.IsNullOrEmpty(currentSort))
                {
                    <input type="hidden" name="sortOrder" value="@currentSort" />
                }

                <div class="search-row">
                    <input type="text" name="searchString" value="@searchString" class="form-control" placeholder="Tiêu đề, nội dung, từ khóa..." />
                    <button type="submit" class="btn btn-primary search-submit" aria-label="Tìm kiếm">
                        <i class="fa-solid fa-arrow-right"></i>
                    </button>
                </div>
            </form>
        </div>
    </aside>
</div>
