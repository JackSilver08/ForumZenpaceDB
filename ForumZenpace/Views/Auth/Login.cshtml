@model ForumZenpace.Models.LoginViewModel
@{
    ViewData["Title"] = "Dang nhap";
}

<div class="auth-shell animated-entry">
    <div class="surface auth-card">
        <div class="auth-header">
            <div class="auth-mark">
                <i class="fa-solid fa-shield-halved"></i>
            </div>
            <h1 class="auth-title">Dang nhap tai khoan</h1>
            <p class="auth-subtitle">Tro lai khong gian thao luan voi giao dien gon hon va tap trung vao noi dung.</p>
        </div>

        <form asp-action="Login" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2 text-center"></div>

            <div class="field">
                <label asp-for="Username" class="field-label">Ten tai khoan</label>
                <div class="input-icon">
                    <i class="fa-solid fa-user"></i>
                    <input asp-for="Username" class="form-control" placeholder="username" />
                </div>
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <div class="field">
                <label asp-for="Password" class="field-label">Mat khau</label>
                <div class="input-icon">
                    <i class="fa-solid fa-lock"></i>
                    <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" />
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%;">Dang nhap</button>

            <div class="auth-footer">
                Chua co tai khoan?
                <a asp-action="Register">Tao tai khoan moi</a>
            </div>
        </form>
    </div>
</div>
