@model ForumZenpace.Models.RegisterViewModel
@{
    ViewData["Title"] = "Dang ky";
}

<div class="auth-shell auth-shell--wide animated-entry">
    <div class="surface auth-card">
        <div class="auth-header">
            <div class="auth-mark">
                <i class="fa-solid fa-user-plus"></i>
            </div>
            <h1 class="auth-title">Tao tai khoan moi</h1>
            <p class="auth-subtitle">Giao dien dang ky duoc rut gon de tap trung vao thong tin can thiet va de quet hon tren desktop.</p>
        </div>

        <form asp-action="Register" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2 text-center"></div>

            <div class="form-grid-2">
                <div class="field">
                    <label asp-for="Username" class="field-label">Ten tai khoan</label>
                    <input asp-for="Username" class="form-control" placeholder="username" />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="field">
                    <label asp-for="FullName" class="field-label">Ho ten</label>
                    <input asp-for="FullName" class="form-control" placeholder="Ho ten cua ban" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>
            </div>

            <div class="field">
                <label asp-for="Email" class="field-label">Email</label>
                <div class="input-icon">
                    <i class="fa-solid fa-envelope"></i>
                    <input asp-for="Email" class="form-control" type="email" placeholder="example@zenpace.com" />
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-grid-2">
                <div class="field">
                    <label asp-for="Password" class="field-label">Mat khau</label>
                    <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="field">
                    <label asp-for="ConfirmPassword" class="field-label">Xac nhan</label>
                    <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%;">Tao tai khoan</button>

            <div class="auth-footer">
                Da co tai khoan?
                <a asp-action="Login">Dang nhap</a>
            </div>
        </form>
    </div>
</div>
