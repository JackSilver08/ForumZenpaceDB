@model ForumZenpace.Models.PostViewModel
@{
    ViewData["Title"] = "Tao chu de moi";
}

<div class="editor-shell animated-entry">
    <div class="surface editor-card">
        <div class="editor-header">
            <div>
                <h1 class="editor-title">Tao chu de moi</h1>
                <p class="editor-subtitle">Form duoc rut gon ve dung nhom spacing 4/8/12/16 de tap trung vao noi dung va giam cam giac mobile-like.</p>
            </div>

            <div class="editor-mark">
                <i class="fa-solid fa-feather-pointed"></i>
            </div>
        </div>

        <form asp-action="Create" method="post" class="editor-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="field">
                <label asp-for="Title" class="field-label">Tieu de</label>
                <input asp-for="Title" class="form-control editor-title-input" placeholder="Dat cau hoi hoac chu de thao luan ro rang" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="field">
                <label asp-for="CategoryId" class="field-label">Chuyen muc</label>
                <div class="select-shell">
                    <select asp-for="CategoryId" class="form-control category-select" asp-items="ViewBag.Categories">
                        <option value="">Chon chuyen muc phu hop</option>
                    </select>
                </div>
                <div class="field-hint">Chon dung khu vuc de bai viet hien thi ro rang hon va de nguoi doc tim thay nhanh hon.</div>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <partial name="_MarkdownEditorField" model="Model" />

            <div class="editor-footer">
                <a asp-controller="Home" asp-action="Index" class="btn btn-text">Quay lai bang tin</a>
                <button type="submit" class="btn btn-primary">Dang chu de</button>
            </div>
        </form>
    </div>
</div>
