@model ForumZenpace.Models.PostViewModel
@{
    ViewData["Title"] = "Chinh sua chu de";
}

<div class="editor-shell animated-entry">
    <div class="surface editor-card">
        <div class="editor-header">
            <div>
                <h1 class="editor-title">Chinh sua chu de</h1>
                <p class="editor-subtitle">Khung sua bai viet giu cung metric voi trang tao moi de tra nghiem viet bai nhat quan hon.</p>
            </div>

            <div class="editor-mark">
                <i class="fa-solid fa-file-pen"></i>
            </div>
        </div>

        <form asp-action="Edit" method="post" class="editor-form">
            <input type="hidden" name="id" value="@ViewBag.PostId" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="field">
                <label asp-for="Title" class="field-label">Tieu de</label>
                <input asp-for="Title" class="form-control editor-title-input" placeholder="Tieu de bai viet" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="field">
                <label asp-for="CategoryId" class="field-label">Chuyen muc</label>
                <div class="select-shell">
                    <select asp-for="CategoryId" class="form-control category-select" asp-items="ViewBag.Categories">
                        <option value="">Chon chuyen muc phu hop</option>
                    </select>
                </div>
                <div class="field-hint">Chuyen muc ro rang giup bai viet duoc sap dung nhom va de theo doi hon khi chinh sua.</div>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <partial name="_MarkdownEditorField" model="Model" />

            <div class="editor-footer">
                <a asp-action="Details" asp-route-id="@ViewBag.PostId" class="btn btn-text">Huy thay doi</a>
                <button type="submit" class="btn btn-primary">Luu cap nhat</button>
            </div>
        </form>
    </div>
</div>
