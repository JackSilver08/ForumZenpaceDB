@using System.Linq
@model ForumZenpace.Models.Post
@{
    ViewData["Title"] = Model.Title;
    var topLevelComments = ViewBag.TopLevelComments as List<ForumZenpace.Models.Comment> ?? new List<ForumZenpace.Models.Comment>();
    int? currentUserId = ViewBag.UserId == null ? null : (int?)ViewBag.UserId;
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var currentUserInitial = isAuthenticated && !string.IsNullOrWhiteSpace(User.Identity?.Name)
        ? User.Identity!.Name!.Substring(0, 1).ToUpperInvariant()
        : "U";
}

<div class="detail-shell animated-entry">
    <div class="surface detail-card">
        <div class="detail-header">
            <div class="detail-kicker">
                <span class="category-badge" style="margin-left: 0;">@Model.Category.Name</span>
                <div class="detail-meta">
                    <span><i class="fa-regular fa-user"></i> @Model.User.FullName</span>
                    <span class="dot"></span>
                    <span>@Model.CreatedAt.ToString("dd MMM yyyy")</span>
                    <span class="dot"></span>
                    <span>@Model.ViewCount luot xem</span>
                </div>
            </div>

            <h1 class="detail-title">@Model.Title</h1>
        </div>

        <div class="detail-content markdown-rendered">@Html.Raw(PostContentFormatter.ToHtml(Model.Content))</div>

        <div class="detail-actions">
            <div class="detail-action-group">
                <form asp-action="ToggleLike" method="post" class="inline-form ajax-postback">
                    <input type="hidden" name="postId" value="@Model.Id" />
                    <button type="submit" class="btn @(ViewBag.HasLiked == true ? "btn-primary" : "btn-outline")">
                        <i class="fa-solid fa-fire-flame-curved"></i>
                        @(ViewBag.HasLiked == true ? "Da de xuat" : "De xuat") (@Model.Likes.Count)
                    </button>
                </form>

                <button type="button" class="btn btn-outline" onclick="toggleReport()">
                    <i class="fa-solid fa-flag"></i> Bao cao
                </button>
            </div>

            @if (User.Identity?.IsAuthenticated == true && ViewBag.UserId == Model.UserId)
            {
                <div class="detail-action-group">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline">
                        <i class="fa-solid fa-pen"></i> Chinh sua
                    </a>

                    <form asp-action="Delete" method="post" class="inline-form" onsubmit="return confirm('Ban co chac chan muon xoa chu de nay?');">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger-soft">
                            <i class="fa-solid fa-trash-can"></i> Xoa
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>

    <div id="reportBox" class="surface detail-report-box" hidden>
        <form asp-action="Report" method="post" class="stack-md ajax-postback">
            <input type="hidden" name="postId" value="@Model.Id" />

            <div>
                <h2 class="section-heading">Bao cao noi dung</h2>
                <p class="muted" style="margin-top: 6px;">Mo ta ly do de quan tri vien co them boi canh khi xu ly.</p>
            </div>

            <div class="report-form-row">
                <input type="text" name="reason" class="form-control" placeholder="Nhap ly do bao cao..." required />
                <div style="display: flex; justify-content: flex-end;">
                    <button type="submit" class="btn btn-primary">Gui bao cao</button>
                </div>
            </div>
        </form>
    </div>

    <div class="surface comment-card">
        <div class="surface-header">
            <div>
                <h2 class="surface-title">Binh luan (@Model.Comments.Count)</h2>
                <p class="surface-subtitle">Comment section duoc thu gon de hien thi duoc nhieu noi dung hon tren cung mot man hinh.</p>
            </div>
        </div>

        @if (isAuthenticated)
        {
            <form asp-action="AddComment" method="post" class="comment-form comment-composer ajax-postback">
                <input type="hidden" name="PostId" value="@Model.Id" />
                <input type="hidden" name="ParentId" value="" />

                <div class="comment-entry">
                    <div class="avatar thread-avatar">@currentUserInitial</div>

                    <div class="comment-composer-panel">
                        <textarea name="Content" class="form-control comment-composer-input" rows="3" placeholder="Dong gop y kien cua ban..." data-emoji-input required></textarea>
                        <div class="comment-composer-actions comment-editor-footer">
                            <button
                                type="button"
                                class="comment-emoji-trigger"
                                data-emoji-trigger
                                title="Dang tai emoji"
                                aria-label="Chen emoji vao binh luan"
                                aria-haspopup="dialog"
                                aria-expanded="false"
                                disabled>
                                <i class="fa-regular fa-face-smile"></i>
                                <span>Emoji</span>
                            </button>

                            <div class="comment-editor-submit-group">
                                <button type="submit" class="btn btn-primary">Gui binh luan</button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        }
        else
        {
            <div class="comment-login-prompt">
                <p class="muted">
                    Ban can
                    <a asp-controller="Auth" asp-action="Login" style="color: var(--accent-blue); font-weight: 800;">dang nhap</a>
                    de tham gia thao luan.
                </p>
            </div>
        }

        <div class="comment-list">
            @if (topLevelComments.Any())
            {
                @foreach (var comment in topLevelComments)
                {
                    var threadItem = new CommentThreadItemViewModel
                    {
                        Comment = comment,
                        Level = 0,
                        PostId = Model.Id,
                        CurrentUserId = currentUserId,
                        IsAuthenticated = isAuthenticated
                    };

                    <partial name="_CommentThreadItem" model="threadItem" />
                }
            }
            else
            {
                <div class="comment-empty-state">
                    Chua co binh luan nao. Hay mo dau chuoi thao luan dau tien.
                </div>
            }
        </div>

        <div
            class="comment-emoji-popover"
            data-emoji-popover
            role="dialog"
            aria-label="Bang chon emoji"
            aria-hidden="true"
            hidden>
            <emoji-picker class="comment-emoji-picker dark" data-emoji-picker></emoji-picker>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleReplyBox(id) {
            const box = document.getElementById(`replyBox-${id}`);
            if (!box) {
                return;
            }

            const isOpen = box.classList.toggle('is-open');
            if (isOpen) {
                const input = box.querySelector('textarea, input');
                if (input instanceof HTMLElement) {
                    input.focus();
                }
            }
        }

        function toggleReplies(id, button) {
            const replies = document.getElementById(`threadReplies-${id}`);
            if (!replies || !(button instanceof HTMLElement)) {
                return;
            }

            const isCollapsed = !replies.hasAttribute('hidden');
            if (isCollapsed) {
                replies.setAttribute('hidden', 'hidden');
                button.classList.add('is-collapsed');
                button.setAttribute('aria-expanded', 'false');
                return;
            }

            replies.removeAttribute('hidden');
            button.classList.remove('is-collapsed');
            button.setAttribute('aria-expanded', 'true');
        }

        function toggleReport() {
            const box = document.getElementById('reportBox');
            if (!box) {
                return;
            }

            const isHidden = box.hasAttribute('hidden');
            if (isHidden) {
                box.removeAttribute('hidden');
                const input = box.querySelector('input, textarea');
                if (input instanceof HTMLElement) {
                    input.focus();
                }
                return;
            }

            box.setAttribute('hidden', 'hidden');
        }

        document.addEventListener('submit', async (event) => {
            const form = event.target;
            if (!(form instanceof HTMLFormElement) || !form.classList.contains('ajax-postback')) {
                return;
            }

            event.preventDefault();

            const submitButton = form.querySelector('button[type="submit"]');
            if (submitButton) {
                submitButton.disabled = true;
                submitButton.style.opacity = '0.7';
            }

            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    body: new FormData(form),
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                if (!response.ok) {
                    alert('Khong the xu ly yeu cau luc nay.');
                    return;
                }

                const data = await response.json();
                if (!data.success) {
                    alert(data.message || 'Yeu cau khong thanh cong.');
                    return;
                }

                if (form.action.includes('Report')) {
                    alert(data.message || 'Da gui bao cao.');
                    form.reset();
                    document.getElementById('reportBox')?.setAttribute('hidden', 'hidden');
                    return;
                }

                window.location.reload();
            } finally {
                if (submitButton) {
                    submitButton.disabled = false;
                    submitButton.style.opacity = '1';
                }
            }
        });
    </script>
    <script type="module" src="https://cdn.jsdelivr.net/npm/emoji-picker-element@@1.29.0/index.js"></script>
    <script src="~/js/comment-emoji.js" asp-append-version="true"></script>
}
